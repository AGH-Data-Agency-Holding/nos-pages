---
const gumroadUrl = "https://aghhol.gumroad.com/l/ramadan-halal-pray-ai";
---
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ramadan Halal AI — Coach de jeûne, scanner halal & Zakat</title>
  <meta name="description" content="Coach IA prédictif pour le Suhoor et l'Iftar, scanner halal instantané, parcours gamifié sur 30 jours et calcul automatique de la Zakat." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #F5F1E6;
      --sand: #E9DFC4;
      --teal: #1E3A45;
      --teal-soft: #2A4B58;
      --sage: #6F9469;
      --sage-dark: #547243;
      --lavender: #9B87C4;
      --gold: #D9B569;
      --ink: #1B2620;
      font-family: Inter, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--cream); color: var(--ink); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 600; letter-spacing: -0.01em; color: var(--teal); margin: 0; }
    .eyebrow { font-family: "JetBrains Mono", monospace; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--sage-dark); font-weight: 700; }
    a { color: inherit; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; font-size: .95rem; padding: 14px 26px; border-radius: 100px; text-decoration: none; transition: transform .15s ease, box-shadow .15s ease; }
    .btn-primary { background: var(--lavender); color: #FBF9FF; box-shadow: 0 8px 22px rgba(155,135,196,.4); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(155,135,196,.48); }
    .btn-ghost { border: 1.5px solid var(--teal); color: var(--teal); }
    .btn-ghost:hover { background: var(--teal); color: var(--cream); }

    header { position: sticky; top: 0; z-index: 40; background: rgba(245,241,230,.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--sand); }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; }
    .brand { display: flex; align-items: center; gap: 8px; text-decoration: none; }
    .brand img { height: 34px; }
    .nav-links { display: flex; gap: 28px; font-size: .92rem; font-weight: 500; }
    .nav-links a { text-decoration: none; color: var(--teal); }
    .nav-links a:hover { color: var(--sage-dark); }
    @media (max-width: 780px) { .nav-links { display: none; } }

    .hero { padding: 70px 0 40px; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 44px; align-items: center; }
    @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero h1 { font-size: clamp(2.2rem, 4.2vw, 3.2rem); line-height: 1.08; margin: 14px 0 18px; }
    .hero h1 em { font-style: italic; color: var(--sage-dark); }
    .hero p.lede { font-size: 1.08rem; line-height: 1.6; color: var(--teal-soft); max-width: 470px; margin-bottom: 28px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
    .trust-line { font-size: .85rem; color: var(--teal-soft); font-family: "JetBrains Mono", monospace; }
    .trust-line strong { color: var(--sage-dark); }
    .hero-visual { display: flex; justify-content: center; position: relative; }
    .crescent {
      position: absolute; width: 340px; height: 340px; border-radius: 50%;
      background: radial-gradient(circle at 35% 30%, rgba(217,181,105,.35), transparent 60%);
      top: 50%; left: 50%; transform: translate(-50%,-50%);
    }
    .phone-frame { position: relative; width: 250px; border-radius: 32px; overflow: hidden; box-shadow: 0 30px 60px rgba(30,58,69,.28); border: 6px solid var(--teal); }

    .stat-band { background: var(--teal); color: var(--cream); padding: 46px 0; }
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
    @media (max-width: 780px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-grid .num { font-family: "Fraunces", serif; font-size: 2rem; color: var(--gold); }
    .stat-grid .label { font-size: .78rem; color: #C9D3CE; font-family: "JetBrains Mono", monospace; letter-spacing: .04em; margin-top: 4px; }

    .feature-section { padding: 100px 0; }
    .feature-row { display: grid; grid-template-columns: .9fr 1.1fr; gap: 54px; align-items: center; margin-bottom: 100px; }
    .feature-row.reverse { grid-template-columns: 1.1fr .9fr; }
    .feature-row.reverse .feature-copy { order: 2; }
    .feature-row.reverse .feature-shot { order: 1; }
    @media (max-width: 860px) {
      .feature-row, .feature-row.reverse { grid-template-columns: 1fr; }
      .feature-row.reverse .feature-copy, .feature-row.reverse .feature-shot { order: unset; }
    }
    .feature-shot { display: flex; justify-content: center; }
    .feature-shot img { width: 100%; max-width: 270px; border-radius: 24px; box-shadow: 0 24px 48px rgba(30,58,69,.18); border: 5px solid #fff; }
    .feature-copy h3 { font-size: 1.6rem; margin: 12px 0 14px; }
    .feature-copy p { color: var(--teal-soft); line-height: 1.65; font-size: 1rem; max-width: 420px; }
    .feature-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .feature-tags span { font-family: "JetBrains Mono", monospace; font-size: .7rem; letter-spacing: .03em; background: var(--sand); color: var(--ink); padding: 6px 12px; border-radius: 100px; }

    .band-sage { background: linear-gradient(120deg, var(--sage) 0%, var(--sage-dark) 100%); color: #F6FBF3; padding: 60px 0; text-align: center; }
    .band-sage .eyebrow { color: #E4F0DE; }
    .band-sage h2 { color: #F6FBF3; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 12px auto 14px; max-width: 640px; }
    .band-sage p { max-width: 540px; margin: 0 auto; color: #E4F0DE; line-height: 1.6; }

    .price-section { padding: 90px 0; text-align: center; }
    .price-card { max-width: 440px; margin: 40px auto 0; background: #fff; border: 1px solid var(--sand); border-radius: 22px; padding: 34px; }
    .price-card .price { font-family: "Fraunces", serif; font-size: 2.6rem; margin: 10px 0 4px; }
    .price-card .price span { font-size: 1rem; font-family: Inter, sans-serif; font-weight: 500; color: var(--teal-soft); }
    .price-card ul { list-style: none; padding: 0; margin: 22px 0 26px; text-align: left; }
    .price-card li { padding: 8px 0; font-size: .94rem; border-top: 1px solid var(--sand); }
    .price-card li:first-child { border-top: none; }


    .tier-list { display: flex; flex-direction: column; gap: 10px; margin: 24px 0 28px; }
    .tier-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-radius: 14px; border: 1px solid rgba(0,0,0,.08);
      background: #fff;
    }
    .tier-row.featured {
      border: 1.5px solid #9B87C4; background: #9B87C410;
      position: relative;
    }
    .tier-name { font-size: .95rem; font-weight: 600; }
    .tier-badge {
      font-family: "JetBrains Mono", monospace; font-size: .62rem; letter-spacing: .04em;
      text-transform: uppercase; color: #9B87C4; font-weight: 700; display: block; margin-top: 2px;
    }
    .tier-price { font-family: "Fraunces", serif; font-weight: 600; font-size: 1.15rem; color: #7B5FD9; white-space: nowrap; }

    .guarantee { padding: 0 0 100px; }
    .guarantee-box { background: var(--sand); border-radius: 24px; padding: 46px; text-align: center; }
    .guarantee-box h2 { font-size: 1.5rem; margin: 10px 0 12px; }
    .guarantee-box p { max-width: 560px; margin: 0 auto; color: var(--ink); line-height: 1.6; }

    .final-cta { background: var(--teal); color: var(--cream); padding: 90px 0; text-align: center; }
    .final-cta h2 { color: #FBF9F0; font-size: clamp(1.8rem, 3.2vw, 2.5rem); margin: 10px 0 16px; }
    .final-cta p { color: #C9D3CE; max-width: 480px; margin: 0 auto 30px; }
    .lang-row { margin-top: 32px; font-family: "JetBrains Mono", monospace; font-size: .78rem; color: #8FA298; letter-spacing: .05em; }

    footer { padding: 34px 0; text-align: center; font-size: .85rem; color: var(--teal-soft); }
  </style>
</head>
<body>

  <header>
    <div class="wrap nav">
      <a class="brand" href="#top">
        <img src="/images/logo.png" alt="Logo Ramadan Halal AI" />
      </a>
      <nav class="nav-links">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#tarif">Tarif</a>
        <a href="#garantie">Garantie</a>
      </nav>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger</a>
    </div>
  </header>

  <section class="hero" id="top">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">Coach IA · Scanner Halal · Zakat</span>
        <h1>Vivez un Ramadan <em>plus serein</em>, jour après jour.</h1>
        <p class="lede">Un coach IA prédictif pour votre Suhoor et Iftar, un scanner qui vérifie l'origine halal de vos aliments en un instant, et un parcours gamifié sur 30 jours pour rester motivé jusqu'à l'Aïd.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger l'app</a>
          <a class="btn btn-ghost" href="#fonctionnalites">Voir les fonctionnalités</a>
        </div>
        <p class="trust-line">100% remboursé si l'app ne vous aide pas · <strong>30 jours de parcours guidé</strong></p>
      </div>
      <div class="hero-visual">
        <div class="crescent"></div>
        <div class="phone-frame">
          <img src="/images/screen-splash.png" alt="Écran de lancement Ramadan Halal AI" />
        </div>
      </div>
    </div>
  </section>

  <section class="stat-band">
    <div class="wrap stat-grid">
      <div>
        <div class="num">92%</div>
        <div class="label">PRÉCISION DU COACH IA</div>
      </div>
      <div>
        <div class="num">50 000+</div>
        <div class="label">INGRÉDIENTS & CODES-E VÉRIFIÉS</div>
      </div>
      <div>
        <div class="num">10 000+</div>
        <div class="label">PRODUITS CERTIFIÉS EN MARKETPLACE</div>
      </div>
      <div>
        <div class="num">30</div>
        <div class="label">JOURS DE PARCOURS GAMIFIÉ</div>
      </div>
    </div>
  </section>

  <section class="feature-section" id="fonctionnalites">
    <div class="wrap">

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-dashboard.png" alt="Tableau de bord quotidien avec compte à rebours Iftar" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Coach de jeûne IA</span>
          <h3>Un coach prédictif pour optimiser Suhoor et Iftar.</h3>
          <p>Le coach IA anticipe vos besoins nutritionnels avec 92% de précision pour gérer les fringales et maintenir votre énergie tout au long du jeûne.</p>
          <div class="feature-tags"><span>PRÉCISION 92%</span><span>SUHOOR & IFTAR</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-scanner.png" alt="Scanner halal des produits alimentaires" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Scanner Halal AR</span>
          <h3>Vérifiez plus de 50 000 ingrédients et codes-E, instantanément.</h3>
          <p>Un simple scan déchiffre les étiquettes complexes pour garantir que votre alimentation reste strictement halal, sans doute ni recherche manuelle.</p>
          <div class="feature-tags"><span>SCAN INSTANTANÉ</span><span>CODES-E</span></div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-coins.png" alt="Système de Pièces Halal et récompenses" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Parcours gamifié 30 jours</span>
          <h3>Un avatar évolutif, des badges Taraweeh, des Pièces Halal.</h3>
          <p>Chaque prière, chaque scan, chaque bonne action rapporte des points. Votre progression spirituelle devient visible, jour après jour.</p>
          <div class="feature-tags"><span>AVATAR 3D</span><span>BADGES</span><span>PIÈCES HALAL</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-community.png" alt="Classement et communauté locale" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Communauté</span>
          <h3>Restez motivé grâce au classement de votre communauté.</h3>
          <p>Comparez votre progression à celle des membres de votre mosquée ou de vos amis, et partagez vos réussites du mois sacré.</p>
          <div class="feature-tags"><span>CLASSEMENT LOCAL</span><span>DÉFIS</span></div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-zakat.png" alt="Calcul et don pour la Zakat" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Zakat & dons</span>
          <h3>Le calcul de la Zakat, automatisé et sans erreur.</h3>
          <p>Un outil intégré calcule vos obligations religieuses financières et simplifie vos dons annuels — pour une tranquillité d'esprit complète.</p>
          <div class="feature-tags"><span>CALCUL AUTOMATIQUE</span><span>DONS</span></div>
        </div>
      </div>

    </div>
  </section>

  <section class="band-sage">
    <div class="wrap">
      <span class="eyebrow">Une expérience complète</span>
      <h2>Transformez vos obligations religieuses quotidiennes en un parcours motivant.</h2>
      <p>Du réveil pour le Suhoor jusqu'à la prière de Taraweeh, chaque étape de votre journée trouve sa place dans l'application.</p>
    </div>
  </section>

  <section class="price-section" id="tarif">
    <span class="eyebrow">Tarif</span>
    <h2 style="margin-top:10px;">Un prix simple, pas d'abonnement caché.</h2>
    <div class="price-card">
      <div class="eyebrow">Ramadan Halal AI</div>
      <div class="tier-list">
        <div class="tier-row">
          <div class="tier-name">Licence d'un mois</div>
          <div class="tier-price">26,22 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Licence de 3 mois</div>
          <div class="tier-price">52,45 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Licence de 6 mois</div>
          <div class="tier-price">104,91 €</div>
        </div>
        <div class="tier-row featured">
          <div class="tier-name">Licence de 12 mois<span class="tier-badge">Le plus choisi</span></div>
          <div class="tier-price">174,86 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Durée de vie</div>
          <div class="tier-price">349,73 €</div>
        </div>
      </div>
      <ul>
        <li>Coach de jeûne IA prédictif</li>
        <li>Scanner halal illimité (50 000+ ingrédients)</li>
        <li>Parcours gamifié sur 30 jours</li>
        <li>Marketplace halal (10 000+ produits certifiés)</li>
        <li>Calculateur de Zakat automatique</li>
      </ul>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="width:100%; justify-content:center;">Télécharger maintenant</a>
    </div>
  </section>

  <section class="guarantee" id="garantie">
    <div class="wrap">
      <div class="guarantee-box">
        <span class="eyebrow">Garantie</span>
        <h2>100% remboursé, sans question posée.</h2>
        <p>Si l'application n'améliore pas significativement votre expérience du jeûne, vous êtes intégralement remboursé, sans justification à donner.</p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="wrap">
      <span class="eyebrow" style="color:#B7C9BE">Prêt à commencer ?</span>
      <h2>Votre Ramadan, guidé et serein, dès aujourd'hui.</h2>
      <p>Téléchargez Ramadan Halal AI et démarrez votre parcours de 30 jours.</p>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger Ramadan Halal AI</a>
      <div class="lang-row">DISPONIBLE EN FRANÇAIS · ENGLISH · العربية · ESPAÑOL</div>
    </div>
  </section>

  <footer>
    <div class="wrap">© 2026 AGH Data Agency Holding — Ramadan Halal AI. Tous droits réservés.</div>
  </footer>

</body>
</html>
