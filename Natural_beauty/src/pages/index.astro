---
const paymentUrl = "https://aghhol.gumroad.com/l/skin-natural-beauty-ai";

// ⚠️ Noms de "variant" par hypothèse (même schéma que Recettes Cuisine).
// À CONFIRMER via l'onglet "Versions" du produit "skin-natural-beauty-ai" sur Gumroad
// avant de considérer cette intégration comme validée.
const tiers = [
  { name: "Licence d'un mois", price: "6,99 €", variant: "1 Month License", featured: false },
  { name: "Licence de 3 mois", price: "17,99 €", variant: "3 Months License", featured: false },
  { name: "Licence de 6 mois", price: "34,99 €", variant: "6 Months License", featured: false },
  { name: "Licence de 12 mois", price: "49,99 €", variant: "12 Months License", featured: true, badge: "Le plus choisi" },
  { name: "Accès à vie", price: "129,99 €", variant: "LIFETIME", featured: false },
];
---
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Natural Beauty — Ta routine beauté naturelle, même hors-ligne</title>
  <meta name="description" content="Recettes DIY pour la peau, les cheveux et le corps, assistant IA 100% hors-ligne, ingrédients simples de cuisine. Sublime ta beauté naturelle, sans connexion." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #FFF6F2;
      --blush: #FBE1EC;
      --pink: #D6247B;
      --pink-dark: #A81760;
      --ink: #2B1420;
      --leaf: #4F7942;
      --line: #F3D9E4;
      font-family: Inter, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--cream); color: var(--ink); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 600; letter-spacing: -0.01em; color: var(--ink); margin: 0; }
    .eyebrow { font-family: "JetBrains Mono", monospace; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--pink-dark); font-weight: 700; }
    a { color: inherit; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; font-size: .95rem; padding: 14px 26px; border-radius: 100px; text-decoration: none; transition: transform .15s ease, box-shadow .15s ease; }
    .btn-primary { background: linear-gradient(120deg, var(--pink), var(--pink-dark)); color: #FFF3F8; box-shadow: 0 8px 22px rgba(214,36,123,.32); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(214,36,123,.4); }
    .btn-ghost { border: 1.5px solid var(--ink); color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--cream); }

    header { position: sticky; top: 0; z-index: 40; background: rgba(255,246,242,.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; }
    .brand { display: flex; align-items: center; gap: 10px; font-family: "Fraunces", serif; font-weight: 700; font-size: 1.15rem; color: var(--ink); text-decoration: none; }
    .brand svg { width: 30px; height: 30px; }
    .nav-links { display: flex; gap: 28px; font-size: .92rem; font-weight: 500; }
    .nav-links a { text-decoration: none; color: var(--ink); }
    .nav-links a:hover { color: var(--pink); }
    @media (max-width: 780px) { .nav-links { display: none; } }

    .hero { padding: 70px 0 30px; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 44px; align-items: center; }
    @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero h1 { font-size: clamp(2.2rem, 4.2vw, 3.2rem); line-height: 1.08; margin: 14px 0 18px; }
    .hero h1 em { font-style: italic; color: var(--pink); }
    .hero p.lede { font-size: 1.08rem; line-height: 1.6; color: #5C4552; max-width: 470px; margin-bottom: 28px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
    .trust-line { font-size: .85rem; color: #5C4552; font-family: "JetBrains Mono", monospace; }
    .trust-line strong { color: var(--pink-dark); }
    .hero-visual { display: flex; justify-content: center; position: relative; }
    .glow { position: absolute; width: 380px; height: 380px; border-radius: 50%; background: radial-gradient(circle, rgba(214,36,123,.16), transparent 65%); top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .phone-frame { position: relative; width: 250px; border-radius: 32px; overflow: hidden; box-shadow: 0 30px 60px rgba(168,23,96,.22); border: 6px solid var(--ink); }

    .stat-band { background: var(--ink); color: #FBE1EC; padding: 46px 0; }
    .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; text-align: center; }
    @media (max-width: 780px) { .stat-grid { grid-template-columns: 1fr; } }
    .stat-grid .num { font-family: "Fraunces", serif; font-size: 2rem; color: #F48FC0; }
    .stat-grid .label { font-size: .76rem; color: #D9AABF; font-family: "JetBrains Mono", monospace; letter-spacing: .04em; margin-top: 4px; }

    .feature-section { padding: 100px 0; }
    .feature-row { display: grid; grid-template-columns: .9fr 1.1fr; gap: 54px; align-items: center; margin-bottom: 100px; }
    .feature-row.reverse { grid-template-columns: 1.1fr .9fr; }
    .feature-row.reverse .feature-copy { order: 2; }
    .feature-row.reverse .feature-shot { order: 1; }
    @media (max-width: 860px) {
      .feature-row, .feature-row.reverse { grid-template-columns: 1fr; }
      .feature-row.reverse .feature-copy, .feature-row.reverse .feature-shot { order: unset; }
    }
    .feature-shot { display: flex; justify-content: center; }
    .feature-shot img { width: 100%; max-width: 270px; border-radius: 24px; box-shadow: 0 24px 48px rgba(43,20,32,.16); border: 5px solid #fff; }
    .feature-copy h3 { font-size: 1.6rem; margin: 12px 0 14px; }
    .feature-copy p { color: #5C4552; line-height: 1.65; font-size: 1rem; max-width: 420px; }
    .feature-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .feature-tags span { font-family: "JetBrains Mono", monospace; font-size: .7rem; letter-spacing: .03em; background: var(--blush); color: var(--pink-dark); padding: 6px 12px; border-radius: 100px; }

    .band-leaf { background: linear-gradient(120deg, var(--leaf) 0%, #3A5C31 100%); color: #F1F5EE; padding: 60px 0; text-align: center; }
    .band-leaf .eyebrow { color: #C7DCC0; }
    .band-leaf h2 { color: #F1F5EE; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 12px auto 14px; max-width: 640px; }
    .band-leaf p { max-width: 540px; margin: 0 auto; color: #DCE9D6; line-height: 1.6; }

    .price-section { padding: 90px 0; text-align: center; }
    .price-card { max-width: 460px; margin: 40px auto 0; background: #fff; border: 1px solid var(--line); border-radius: 22px; padding: 34px; }
    .price-card ul { list-style: none; padding: 0; margin: 22px 0 26px; text-align: left; }
    .price-card li { padding: 8px 0; font-size: .94rem; border-top: 1px solid var(--line); }
    .price-card li:first-child { border-top: none; }
    .price-hint { font-size: .82rem; color: #916078; margin: 0 0 18px; }

    /* Chaque ligne de tarif est un lien cliquable qui ouvre le paiement en pop-up
       directement sur la version correspondante. */
    .tier-list { display: flex; flex-direction: column; gap: 10px; margin: 24px 0 4px; }
    .tier-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-radius: 14px; border: 1px solid rgba(0,0,0,.08);
      background: #fff; text-decoration: none; color: inherit; cursor: pointer;
      transition: border-color .15s ease, background .15s ease, transform .15s ease;
    }
    .tier-row:hover { border-color: var(--pink); background: #FFF6F2; transform: translateY(-1px); }
    .tier-row.featured { border: 1.5px solid #D6247B; background: #D6247B10; position: relative; }
    .tier-row.featured:hover { background: #D6247B18; }
    .tier-name { font-size: .95rem; font-weight: 600; }
    .tier-badge {
      font-family: "JetBrains Mono", monospace; font-size: .62rem; letter-spacing: .04em;
      text-transform: uppercase; color: #D6247B; font-weight: 700; display: block; margin-top: 2px;
    }
    .tier-right { display: flex; align-items: center; gap: 10px; }
    .tier-price { font-family: "Fraunces", serif; font-weight: 600; font-size: 1.15rem; color: #A81760; white-space: nowrap; }
    .tier-arrow { font-size: 1.1rem; color: #A81760; }

    .guarantee { padding: 0 0 100px; }
    .guarantee-box { background: var(--blush); border-radius: 24px; padding: 46px; text-align: center; }
    .guarantee-box h2 { font-size: 1.5rem; margin: 10px 0 12px; }
    .guarantee-box p { max-width: 560px; margin: 0 auto; color: var(--ink); line-height: 1.6; }

    .final-cta { background: var(--ink); color: #FBE1EC; padding: 90px 0; text-align: center; }
    .final-cta h2 { color: #FFF3F8; font-size: clamp(1.8rem, 3.2vw, 2.5rem); margin: 10px 0 16px; }
    .final-cta p { color: #D9AABF; max-width: 480px; margin: 0 auto 30px; }
    .lang-row { margin-top: 32px; font-family: "JetBrains Mono", monospace; font-size: .78rem; color: #916078; letter-spacing: .05em; }

    footer { padding: 34px 0; text-align: center; font-size: .85rem; color: #5C4552; }
  </style>
</head>
<body>

  <header>
    <div class="wrap nav">
      <a class="brand" href="#top">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 6C15 10 10 18 10 26c0 8 6 14 14 14s14-6 14-14c0-8-5-16-14-20Z" fill="#D6247B"/>
          <path d="M24 14c-4 3-7 8-7 12 0 4.5 3 8 7 8" stroke="#FFF3F8" stroke-width="2" fill="none" stroke-linecap="round"/>
        </svg>
        Natural Beauty
      </a>
      <nav class="nav-links">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#tarif">Tarif</a>
        <a href="#garantie">Garantie</a>
      </nav>
      <a class="btn btn-primary" href={paymentUrl} data-gumroad-overlay-checkout="true">Télécharger</a>
    </div>
  </header>

  <section class="hero" id="top">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">Recettes DIY · IA hors-ligne</span>
        <h1>Ta beauté naturelle, <em>même sans réseau</em>.</h1>
        <p class="lede">Des centaines de recettes maison pour la peau, les cheveux et le corps, avec un assistant IA qui te conseille instantanément — même en avion, même sans Wi-Fi.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={paymentUrl} data-gumroad-overlay-checkout="true">Télécharger l'app</a>
          <a class="btn btn-ghost" href="#fonctionnalites">Voir les fonctionnalités</a>
        </div>
        <p class="trust-line">100% remboursé si l'app ne t'aide pas · <strong>zéro connexion requise</strong></p>
      </div>
      <div class="hero-visual">
        <div class="glow"></div>
        <div class="phone-frame">
          <img src="/images/screen-onboarding-1.png" alt="Découvre ta beauté naturelle avec l'app" />
        </div>
      </div>
    </div>
  </section>

  <section class="stat-band">
    <div class="wrap stat-grid">
      <div>
        <div class="num">100%</div>
        <div class="label">FONCTIONNE HORS-LIGNE</div>
      </div>
      <div>
        <div class="num">🌿</div>
        <div class="label">INGRÉDIENTS DE CUISINE</div>
      </div>
      <div>
        <div class="num">🔄</div>
        <div class="label">NOUVELLES RECETTES RÉGULIÈREMENT</div>
      </div>
    </div>
  </section>

  <section class="feature-section" id="fonctionnalites">
    <div class="wrap">

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-scan.png" alt="Analyse instantanée de la peau" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Analyse instantanée</span>
          <h3>Une photo suffit pour connaître les besoins de ta peau.</h3>
          <p>Prends une photo rapide pour révéler ton type de peau et tes besoins spécifiques, puis reçois des solutions naturelles personnalisées.</p>
          <div class="feature-tags"><span>ANALYSE PHOTO</span><span>PERSONNALISÉ</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-photo-choice.png" alt="Prendre ou choisir une photo pour l'analyse" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Simple d'utilisation</span>
          <h3>Prends une photo ou choisis-en une existante.</h3>
          <p>Que tu prennes une photo sur le moment ou que tu utilises une image déjà sur ton téléphone, l'analyse démarre en un tap.</p>
          <div class="feature-tags"><span>APPAREIL PHOTO</span><span>GALERIE</span></div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-home.png" alt="Tableau de bord et niveau de beauté" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Ton niveau de beauté</span>
          <h3>Suis ta progression et découvre de nouvelles inspirations chaque jour.</h3>
          <p>Un tableau de bord clair pour visualiser ta routine, accéder à l'assistant IA, et découvrir des idées beauté fraîches régulièrement.</p>
          <div class="feature-tags"><span>SUIVI DE ROUTINE</span><span>INSPIRATIONS</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-profile.png" alt="Profil avec allergies et statistiques" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Profil personnalisé</span>
          <h3>Renseigne tes allergies, l'app s'adapte à toi.</h3>
          <p>Type de peau, allergies, historique de recettes testées — l'app garde tout en mémoire pour ne te proposer que ce qui te convient vraiment.</p>
          <div class="feature-tags"><span>ALLERGIES</span><span>HISTORIQUE</span></div>
        </div>
      </div>

    </div>
  </section>

  <section class="band-leaf">
    <div class="wrap">
      <span class="eyebrow">Ingrédients de ta cuisine</span>
      <h2>Pas besoin de produits coûteux — juste ce que tu as déjà chez toi.</h2>
      <p>Les recettes utilisent des ingrédients simples, économiques et naturels, pour une routine beauté saine sans se ruiner.</p>
    </div>
  </section>

  <section class="price-section" id="tarif">
    <span class="eyebrow">Tarif</span>
    <h2 style="margin-top:10px;">Choisissez la durée qui vous convient.</h2>
    <div class="price-card">
      <div class="eyebrow">Natural Beauty</div>
      <p class="price-hint">Cliquez sur une licence pour ouvrir directement le paiement correspondant.</p>

      <div class="tier-list">
        {tiers.map((tier) => (
          <a
            class={`tier-row ${tier.featured ? "featured" : ""}`}
            href={`${paymentUrl}?variant=${encodeURIComponent(tier.variant)}`}
            data-gumroad-overlay-checkout="true"
          >
            <div class="tier-name">
              {tier.name}
              {tier.badge && <span class="tier-badge">{tier.badge}</span>}
            </div>
            <div class="tier-right">
              <div class="tier-price">{tier.price}</div>
              <div class="tier-arrow">→</div>
            </div>
          </a>
        ))}
      </div>

      <ul>
        <li>Centaines de recettes DIY (peau, cheveux, corps)</li>
        <li>Assistant IA 100% hors-ligne</li>
        <li>Analyse de peau par photo</li>
        <li>Favoris & historique de routine</li>
        <li>Mises à jour régulières</li>
      </ul>
    </div>
  </section>

  <section class="guarantee" id="garantie">
    <div class="wrap">
      <div class="guarantee-box">
        <span class="eyebrow">Garantie</span>
        <h2>100% remboursé, sans question posée.</h2>
        <p>Si l'application ne t'aide pas à révéler ta beauté naturelle, tu es intégralement remboursée, sans justification à donner.</p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="wrap">
      <span class="eyebrow" style="color:#916078">Prête à révéler ton éclat naturel ?</span>
      <h2>Ta routine beauté t'attend, connectée ou non.</h2>
      <p>Télécharge Natural Beauty et lance ta première analyse dès aujourd'hui.</p>
      <a class="btn btn-primary" href={paymentUrl} data-gumroad-overlay-checkout="true">Télécharger Natural Beauty</a>
      <div class="lang-row">DISPONIBLE EN FRANÇAIS · ENGLISH · العربية</div>
    </div>
  </section>

  <footer>
    <div class="wrap">© 2026 AGH Data Agency Holding — Natural Beauty. Tous droits réservés.</div>
  </footer>

  <!-- Script du prestataire de paiement : détecte les liens pointant vers le domaine de paiement et ouvre le paiement en pop-up.
       is:inline est OBLIGATOIRE : sans ça, Astro bundle ce script externe via Vite, ce qui provoque une erreur CORS au chargement. -->
  <script src="https://gumroad.com/js/gumroad.js" is:inline></script>

</body>
</html>