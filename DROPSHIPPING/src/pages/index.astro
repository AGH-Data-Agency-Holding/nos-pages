---
const gumroadUrl = "https://aghhol.gumroad.com/l/dropshopping-winning-product-ai";
---
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Winning Items — Trouve tes produits gagnants, même hors-ligne</title>
  <meta name="description" content="IA hors-ligne d'analyse de tendances pour le dropshipping. Trouve des produits rentables, des niches inexploitées et des fiches produit détaillées, sans connexion internet." />
  <link rel="icon" href="/images/icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #FBF3EA;
      --sand: #F3DFC8;
      --orange: #F2740A;
      --orange-dark: #C25807;
      --ink: #201408;
      --navy: #241608;
      --green: #1F9D55;
      --line: #F0DCC0;
      font-family: Inter, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--cream); color: var(--ink); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 600; letter-spacing: -0.01em; color: var(--navy); margin: 0; }
    .eyebrow { font-family: "JetBrains Mono", monospace; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--orange-dark); font-weight: 700; }
    a { color: inherit; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; font-size: .95rem; padding: 14px 26px; border-radius: 100px; text-decoration: none; transition: transform .15s ease, box-shadow .15s ease; }
    .btn-primary { background: var(--orange); color: #FFF6EC; box-shadow: 0 8px 22px rgba(242,116,10,.35); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(242,116,10,.42); }
    .btn-ghost { border: 1.5px solid var(--navy); color: var(--navy); }
    .btn-ghost:hover { background: var(--navy); color: var(--cream); }

    header { position: sticky; top: 0; z-index: 40; background: rgba(251,243,234,.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; }
    .brand { display: flex; align-items: center; gap: 10px; font-family: "Fraunces", serif; font-weight: 700; font-size: 1.15rem; color: var(--navy); text-decoration: none; }
    .brand img { width: 32px; height: 32px; border-radius: 9px; }
    .nav-links { display: flex; gap: 28px; font-size: .92rem; font-weight: 500; }
    .nav-links a { text-decoration: none; color: var(--navy); }
    .nav-links a:hover { color: var(--orange); }
    @media (max-width: 780px) { .nav-links { display: none; } }

    .hero { padding: 70px 0 30px; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 44px; align-items: center; }
    @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero h1 { font-size: clamp(2.2rem, 4.2vw, 3.2rem); line-height: 1.08; margin: 14px 0 18px; }
    .hero h1 em { font-style: italic; color: var(--orange); }
    .hero p.lede { font-size: 1.08rem; line-height: 1.6; color: #5A4632; max-width: 470px; margin-bottom: 28px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
    .trust-line { font-size: .85rem; color: #5A4632; font-family: "JetBrains Mono", monospace; }
    .trust-line strong { color: var(--green); }
    .hero-visual { display: flex; justify-content: center; position: relative; }
    .glow { position: absolute; width: 380px; height: 380px; border-radius: 50%; background: radial-gradient(circle, rgba(242,116,10,.16), transparent 65%); top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .phone-frame { position: relative; width: 250px; border-radius: 32px; overflow: hidden; box-shadow: 0 30px 60px rgba(36,22,8,.22); border: 6px solid var(--navy); }

    .stat-band { background: var(--navy); color: #F5EBDC; padding: 46px 0; }
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
    @media (max-width: 780px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-grid .num { font-family: "Fraunces", serif; font-size: 2rem; color: var(--orange); }
    .stat-grid .label { font-size: .76rem; color: #B79E80; font-family: "JetBrains Mono", monospace; letter-spacing: .04em; margin-top: 4px; }

    .feature-section { padding: 100px 0; }
    .feature-row { display: grid; grid-template-columns: .9fr 1.1fr; gap: 54px; align-items: center; margin-bottom: 100px; }
    .feature-row.reverse { grid-template-columns: 1.1fr .9fr; }
    .feature-row.reverse .feature-copy { order: 2; }
    .feature-row.reverse .feature-shot { order: 1; }
    @media (max-width: 860px) {
      .feature-row, .feature-row.reverse { grid-template-columns: 1fr; }
      .feature-row.reverse .feature-copy, .feature-row.reverse .feature-shot { order: unset; }
    }
    .feature-shot { display: flex; justify-content: center; }
    .feature-shot img { width: 100%; max-width: 270px; border-radius: 24px; box-shadow: 0 24px 48px rgba(36,22,8,.18); border: 5px solid #fff; }
    .feature-copy h3 { font-size: 1.6rem; margin: 12px 0 14px; }
    .feature-copy p { color: #5A4632; line-height: 1.65; font-size: 1rem; max-width: 420px; }
    .feature-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .feature-tags span { font-family: "JetBrains Mono", monospace; font-size: .7rem; letter-spacing: .03em; background: var(--sand); color: var(--ink); padding: 6px 12px; border-radius: 100px; }

    .band-orange { background: linear-gradient(120deg, var(--orange) 0%, var(--orange-dark) 100%); color: #FFF6EC; padding: 60px 0; text-align: center; }
    .band-orange .eyebrow { color: #FFE0BF; }
    .band-orange h2 { color: #FFF6EC; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 12px auto 14px; max-width: 640px; }
    .band-orange p { max-width: 540px; margin: 0 auto; color: #FFE9D3; line-height: 1.6; }

    .price-section { padding: 90px 0; text-align: center; }
    .price-card { max-width: 440px; margin: 40px auto 0; background: #fff; border: 1px solid var(--line); border-radius: 22px; padding: 34px; }
    .price-card .price { font-family: "Fraunces", serif; font-size: 2.6rem; margin: 10px 0 4px; }
    .price-card .price span { font-size: 1rem; font-family: Inter, sans-serif; font-weight: 500; color: #5A4632; }
    .price-card ul { list-style: none; padding: 0; margin: 22px 0 26px; text-align: left; }
    .price-card li { padding: 8px 0; font-size: .94rem; border-top: 1px solid var(--line); }
    .price-card li:first-child { border-top: none; }


    .tier-list { display: flex; flex-direction: column; gap: 10px; margin: 24px 0 28px; }
    .tier-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-radius: 14px; border: 1px solid rgba(0,0,0,.08);
      background: #fff;
    }
    .tier-row.featured {
      border: 1.5px solid #F2740A; background: #F2740A10;
      position: relative;
    }
    .tier-name { font-size: .95rem; font-weight: 600; }
    .tier-badge {
      font-family: "JetBrains Mono", monospace; font-size: .62rem; letter-spacing: .04em;
      text-transform: uppercase; color: #F2740A; font-weight: 700; display: block; margin-top: 2px;
    }
    .tier-price { font-family: "Fraunces", serif; font-weight: 600; font-size: 1.15rem; color: #C25807; white-space: nowrap; }

    .guarantee { padding: 0 0 100px; }
    .guarantee-box { background: var(--sand); border-radius: 24px; padding: 46px; text-align: center; }
    .guarantee-box h2 { font-size: 1.5rem; margin: 10px 0 12px; }
    .guarantee-box p { max-width: 560px; margin: 0 auto; color: var(--ink); line-height: 1.6; }

    .final-cta { background: var(--navy); color: #F5EBDC; padding: 90px 0; text-align: center; }
    .final-cta h2 { color: #FFF6EC; font-size: clamp(1.8rem, 3.2vw, 2.5rem); margin: 10px 0 16px; }
    .final-cta p { color: #C7B49B; max-width: 480px; margin: 0 auto 30px; }
    .lang-row { margin-top: 32px; font-family: "JetBrains Mono", monospace; font-size: .78rem; color: #8A7658; letter-spacing: .05em; }

    footer { padding: 34px 0; text-align: center; font-size: .85rem; color: #5A4632; }
  </style>
</head>
<body>

  <header>
    <div class="wrap nav">
      <a class="brand" href="#top">
        <img src="/images/icon.png" alt="Logo Winning Items" />
        Winning Items
      </a>
      <nav class="nav-links">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#tarif">Tarif</a>
        <a href="#garantie">Garantie</a>
      </nav>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger</a>
    </div>
  </header>

  <section class="hero" id="top">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">IA hors-ligne · Dropshipping</span>
        <h1>Trouve ton prochain <em>produit gagnant</em>, sans y passer des heures.</h1>
        <p class="lede">Winning Items analyse les tendances du marché et te propose des idées de produits rentables grâce à une IA embarquée — aucune connexion internet requise pour chercher.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger l'app</a>
          <a class="btn btn-ghost" href="#fonctionnalites">Voir les fonctionnalités</a>
        </div>
        <p class="trust-line">100% remboursé si l'app ne t'aide pas · <strong>fonctionne hors-ligne</strong></p>
      </div>
      <div class="hero-visual">
        <div class="glow"></div>
        <div class="phone-frame">
          <img src="/images/screen-home.png" alt="Tableau de bord Winning Items avec score de rentabilité" />
        </div>
      </div>
    </div>
  </section>

  <section class="stat-band">
    <div class="wrap stat-grid">
      <div>
        <div class="num">100%</div>
        <div class="label">FONCTIONNE HORS-LIGNE</div>
      </div>
      <div>
        <div class="num">0€</div>
        <div class="label">BUDGET PUB GASPILLÉ EN MOINS</div>
      </div>
      <div>
        <div class="num">24/7</div>
        <div class="label">RECHERCHE DE PRODUITS</div>
      </div>
      <div>
        <div class="num">🔄</div>
        <div class="label">MISES À JOUR RÉGULIÈRES</div>
      </div>
    </div>
  </section>

  <section class="feature-section" id="fonctionnalites">
    <div class="wrap">

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-search.png" alt="Recherche de produit gagnant par mot-clé et filtres" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Recherche intelligente</span>
          <h3>Filtre par catégories tendance, marge élevée ou score de viralité.</h3>
          <p>Trouve rapidement les produits qui correspondent à ta stratégie, sans te noyer dans des centaines de résultats non pertinents.</p>
          <div class="feature-tags"><span>FILTRES AVANCÉS</span><span>SCORE DE VIRALITÉ</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-benchmark.png" alt="Benchmark produit avec marge et données de vente" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Fiches produit détaillées</span>
          <h3>Marge, prix fournisseur, ventes mensuelles — tout au même endroit.</h3>
          <p>Chaque produit suggéré vient avec une fiche complète : prix de vente recommandé, marge nette, tendance et niveau de concurrence.</p>
          <div class="feature-tags"><span>MARGE NETTE</span><span>DONNÉES DE VENTE</span></div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-dashboard.png" alt="Tableau de bord avec statistiques de recherche" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Suivi de ton activité</span>
          <h3>Visualise le temps que tu économises et ta progression.</h3>
          <p>Fiches produits analysées, temps de recherche économisé, taux de succès — un tableau de bord clair pour mesurer l'impact réel de l'app sur ton activité.</p>
          <div class="feature-tags"><span>STATISTIQUES</span><span>GAIN DE TEMPS</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-profile.png" alt="Profil utilisateur avec favoris et statistiques" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Ton espace personnel</span>
          <h3>Garde tes produits favoris et suis ton score de recherche.</h3>
          <p>Retrouve tes produits sauvegardés, ton nombre de vues et ton score global pour affiner ta stratégie au fil du temps.</p>
          <div class="feature-tags"><span>FAVORIS</span><span>HISTORIQUE</span></div>
        </div>
      </div>

    </div>
  </section>

  <section class="band-orange">
    <div class="wrap">
      <span class="eyebrow">Zéro connexion requise</span>
      <h2>Cherche des produits gagnants où que tu sois, même sans réseau.</h2>
      <p>L'IA embarquée analyse les tendances directement sur ton téléphone — utile en déplacement, en zone peu connectée, ou simplement pour économiser ta data.</p>
    </div>
  </section>

  <section class="price-section" id="tarif">
    <span class="eyebrow">Tarif</span>
    <h2 style="margin-top:10px;">Un prix simple, pas d'abonnement caché.</h2>
    <div class="price-card">
      <div class="eyebrow">Winning Items</div>
      <div class="tier-list">
        <div class="tier-row">
          <div class="tier-name">Licence d'un mois</div>
          <div class="tier-price">14,99 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Licence de 3 mois</div>
          <div class="tier-price">37,99 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Licence de 6 mois</div>
          <div class="tier-price">74,99 €</div>
        </div>
        <div class="tier-row featured">
          <div class="tier-name">Licence de 12 mois<span class="tier-badge">Le plus choisi</span></div>
          <div class="tier-price">99,99 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Durée de vie</div>
          <div class="tier-price">129,99 €</div>
        </div>
      </div>
      <ul>
        <li>Suggestions de produits par IA hors-ligne</li>
        <li>Analyse de tendances et de niches</li>
        <li>Fiches produit détaillées</li>
        <li>Catégories multiples et variées</li>
        <li>Mises à jour régulières</li>
      </ul>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="width:100%; justify-content:center;">Télécharger maintenant</a>
    </div>
  </section>

  <section class="guarantee" id="garantie">
    <div class="wrap">
      <div class="guarantee-box">
        <span class="eyebrow">Garantie</span>
        <h2>100% remboursé, sans question posée.</h2>
        <p>Si l'application ne t'aide pas à trouver des produits rentables, tu es intégralement remboursé, sans justification à donner.</p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="wrap">
      <span class="eyebrow" style="color:#8A7658">Prêt à trouver ton best-seller ?</span>
      <h2>Ton prochain produit gagnant t'attend.</h2>
      <p>Télécharge Winning Items et lance ta première recherche dès aujourd'hui.</p>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger Winning Items</a>
      <div class="lang-row">DISPONIBLE EN FRANÇAIS · ENGLISH · العربية · ESPAÑOL</div>
    </div>
  </section>

  <footer>
    <div class="wrap">© 2026 AGH Data Agency Holding — Winning Items. Tous droits réservés.</div>
  </footer>

</body>
</html>
