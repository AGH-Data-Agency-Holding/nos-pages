---
const paymentUrl = "https://aghhol.gumroad.com/l/fitness-coach-smart-ai";

// ⚠️ Noms de "variant" par hypothèse (même schéma que les apps précédentes).
// À CONFIRMER via l'onglet "Versions" du produit "fitness-coach-smart-ai" sur Gumroad
// avant de considérer cette intégration comme validée.
const tiers = [
  { name: "Licence d'un mois", price: "9,99 €", variant: "1 Month License", featured: false },
  { name: "Licence de 3 mois", price: "24,99 €", variant: "3 Months License", featured: false },
  { name: "Licence de 6 mois", price: "47,99 €", variant: "6 Months License", featured: false },
  { name: "Licence de 12 mois", price: "69,99 €", variant: "12 Months License", featured: true, badge: "Le plus choisi" },
  { name: "Accès à vie", price: "129,99 €", variant: "LIFETIME", featured: false },
];
---
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MARCO — Ton coach fitness IA, chez toi, même hors-ligne</title>
  <meta name="description" content="Programmes personnalisés, coach IA conversationnel, bibliothèque de 150+ exercices vidéo, adaptation au Ramadan. Aucune salle de sport requise." />
  <link rel="icon" href="/images/icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --navy: #0A1330;
      --navy-soft: #131E3D;
      --navy-line: #22305A;
      --cream: #F3F6FB;
      --teal: #1FC2B0;
      --blue: #2E86E0;
      --ink: #101826;
      font-family: Inter, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--cream); color: var(--ink); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 600; letter-spacing: -0.01em; color: var(--navy); margin: 0; }
    .eyebrow { font-family: "JetBrains Mono", monospace; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--blue); font-weight: 700; }
    a { color: inherit; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; font-size: .95rem; padding: 14px 26px; border-radius: 100px; text-decoration: none; transition: transform .15s ease, box-shadow .15s ease; }
    .btn-primary { background: linear-gradient(120deg, var(--teal), var(--blue)); color: #04121C; box-shadow: 0 8px 22px rgba(46,134,224,.35); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(46,134,224,.42); }
    .btn-ghost { border: 1.5px solid var(--navy); color: var(--navy); }
    .btn-ghost:hover { background: var(--navy); color: #fff; }

    header { position: sticky; top: 0; z-index: 40; background: rgba(243,246,251,.9); backdrop-filter: blur(10px); border-bottom: 1px solid #DEE6F0; }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; }
    .brand { display: flex; align-items: center; gap: 10px; font-family: "Fraunces", serif; font-weight: 700; font-size: 1.15rem; color: var(--navy); text-decoration: none; }
    .brand img { width: 32px; height: 32px; border-radius: 9px; }
    .nav-links { display: flex; gap: 28px; font-size: .92rem; font-weight: 500; }
    .nav-links a { text-decoration: none; color: var(--navy); }
    .nav-links a:hover { color: var(--blue); }
    @media (max-width: 780px) { .nav-links { display: none; } }

    .hero { padding: 70px 0 30px; background: var(--navy); color: #EAF1FB; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 44px; align-items: center; }
    @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero h1 { color: #F5F8FF; font-size: clamp(2.2rem, 4.2vw, 3.2rem); line-height: 1.08; margin: 14px 0 18px; }
    .hero h1 em { font-style: italic; background: linear-gradient(120deg, var(--teal), var(--blue)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .hero p.lede { font-size: 1.08rem; line-height: 1.6; color: #B9C6DE; max-width: 470px; margin-bottom: 28px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
    .trust-line { font-size: .85rem; color: #8FA0C2; font-family: "JetBrains Mono", monospace; }
    .trust-line strong { color: var(--teal); }
    .hero-visual { display: flex; justify-content: center; position: relative; padding: 20px 0; }
    .glow { position: absolute; width: 380px; height: 380px; border-radius: 50%; background: radial-gradient(circle, rgba(31,194,176,.28), transparent 65%); top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .phone-frame { position: relative; width: 250px; border-radius: 32px; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,.4); border: 6px solid #1B2748; }

    .stat-band { background: var(--navy-soft); color: #EAF1FB; padding: 46px 0; border-top: 1px solid var(--navy-line); }
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
    @media (max-width: 780px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-grid .num { font-family: "Fraunces", serif; font-size: 2rem; background: linear-gradient(120deg, var(--teal), var(--blue)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .stat-grid .label { font-size: .76rem; color: #8FA0C2; font-family: "JetBrains Mono", monospace; letter-spacing: .04em; margin-top: 4px; }

    .feature-section { padding: 100px 0; }
    .feature-row { display: grid; grid-template-columns: .9fr 1.1fr; gap: 54px; align-items: center; margin-bottom: 100px; }
    .feature-row.reverse { grid-template-columns: 1.1fr .9fr; }
    .feature-row.reverse .feature-copy { order: 2; }
    .feature-row.reverse .feature-shot { order: 1; }
    @media (max-width: 860px) {
      .feature-row, .feature-row.reverse { grid-template-columns: 1fr; }
      .feature-row.reverse .feature-copy, .feature-row.reverse .feature-shot { order: unset; }
    }
    .feature-shot { display: flex; justify-content: center; }
    .feature-shot img { width: 100%; max-width: 270px; border-radius: 24px; box-shadow: 0 24px 48px rgba(10,19,48,.18); border: 5px solid #fff; }
    .feature-copy h3 { font-size: 1.6rem; margin: 12px 0 14px; }
    .feature-copy p { color: #47526B; line-height: 1.65; font-size: 1rem; max-width: 420px; }
    .feature-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .feature-tags span { font-family: "JetBrains Mono", monospace; font-size: .7rem; letter-spacing: .03em; background: #E4EEF9; color: var(--navy); padding: 6px 12px; border-radius: 100px; }

    .band-gradient { background: linear-gradient(120deg, var(--teal) 0%, var(--blue) 100%); color: #04121C; padding: 60px 0; text-align: center; }
    .band-gradient .eyebrow { color: #06342E; }
    .band-gradient h2 { color: #04121C; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 12px auto 14px; max-width: 640px; }
    .band-gradient p { max-width: 540px; margin: 0 auto; color: #0A2A24; line-height: 1.6; }

    .price-section { padding: 90px 0; text-align: center; }
    .price-card { max-width: 460px; margin: 40px auto 0; background: #fff; border: 1px solid #DEE6F0; border-radius: 22px; padding: 34px; }
    .price-card ul { list-style: none; padding: 0; margin: 22px 0 26px; text-align: left; }
    .price-card li { padding: 8px 0; font-size: .94rem; border-top: 1px solid #E4EEF9; }
    .price-card li:first-child { border-top: none; }
    .price-hint { font-size: .82rem; color: #5A6784; margin: 0 0 18px; }

    .tier-list { display: flex; flex-direction: column; gap: 10px; margin: 24px 0 4px; }
    .tier-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-radius: 14px; border: 1px solid rgba(0,0,0,.08);
      background: #fff; text-decoration: none; color: inherit; cursor: pointer;
      transition: border-color .15s ease, background .15s ease, transform .15s ease;
    }
    .tier-row:hover { border-color: var(--blue); background: #F3F6FB; transform: translateY(-1px); }
    .tier-row.featured { border: 1.5px solid #2E86E0; background: #2E86E010; position: relative; }
    .tier-row.featured:hover { background: #2E86E018; }
    .tier-name { font-size: .95rem; font-weight: 600; }
    .tier-badge {
      font-family: "JetBrains Mono", monospace; font-size: .62rem; letter-spacing: .04em;
      text-transform: uppercase; color: #2E86E0; font-weight: 700; display: block; margin-top: 2px;
    }
    .tier-right { display: flex; align-items: center; gap: 10px; }
    .tier-price { font-family: "Fraunces", serif; font-weight: 600; font-size: 1.15rem; color: #1FC2B0; white-space: nowrap; }
    .tier-arrow { font-size: 1.1rem; color: #1FC2B0; }

    .guarantee { padding: 0 0 100px; }
    .guarantee-box { background: #E4EEF9; border-radius: 24px; padding: 46px; text-align: center; }
    .guarantee-box h2 { font-size: 1.5rem; margin: 10px 0 12px; }
    .guarantee-box p { max-width: 560px; margin: 0 auto; color: var(--ink); line-height: 1.6; }

    .final-cta { background: var(--navy); color: #EAF1FB; padding: 90px 0; text-align: center; }
    .final-cta h2 { color: #F5F8FF; font-size: clamp(1.8rem, 3.2vw, 2.5rem); margin: 10px 0 16px; }
    .final-cta p { color: #B9C6DE; max-width: 480px; margin: 0 auto 30px; }
    .lang-row { margin-top: 32px; font-family: "JetBrains Mono", monospace; font-size: .78rem; color: #5E6E92; letter-spacing: .05em; }

    footer { padding: 34px 0; text-align: center; font-size: .85rem; color: #47526B; }
  </style>
</head>
<body>

  <header>
    <div class="wrap nav">
      <a class="brand" href="#top">
        <img src="/images/icon.png" alt="Logo MARCO" />
        MARCO
      </a>
      <nav class="nav-links">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#tarif">Tarif</a>
        <a href="#garantie">Garantie</a>
      </nav>
      <a class="btn btn-primary" href={paymentUrl} data-gumroad-overlay-checkout="true">Télécharger</a>
    </div>
  </header>

  <section class="hero" id="top">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">Coach IA · Chez toi · Sans salle de sport</span>
        <h1>Ton coach fitness, <em>adapté à ta vie</em>, pas l'inverse.</h1>
        <p class="lede">Pas de salle de sport, pas de matériel ? Aucun problème. MARCO construit un programme qui respecte tes contraintes, ton emploi du temps et même le Ramadan.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={paymentUrl} data-gumroad-overlay-checkout="true">Télécharger l'app</a>
          <a class="btn btn-ghost" style="border-color:#fff;color:#fff" href="#fonctionnalites">Voir les fonctionnalités</a>
        </div>
        <p class="trust-line">100% remboursé si l'app ne t'aide pas · <strong>fonctionne hors-ligne</strong></p>
      </div>
      <div class="hero-visual">
        <div class="glow"></div>
        <div class="phone-frame">
          <img src="/images/screen-home.png" alt="Tableau de bord d'entraînement MARCO" />
        </div>
      </div>
    </div>
  </section>

  <section class="stat-band">
    <div class="wrap stat-grid">
      <div>
        <div class="num">150+</div>
        <div class="label">EXERCICES VIDÉO HD</div>
      </div>
      <div>
        <div class="num">24/7</div>
        <div class="label">COACH IA DISPONIBLE</div>
      </div>
      <div>
        <div class="num">0</div>
        <div class="label">ÉQUIPEMENT REQUIS</div>
      </div>
      <div>
        <div class="num">100%</div>
        <div class="label">FONCTIONNE HORS-LIGNE</div>
      </div>
    </div>
  </section>

  <section class="feature-section" id="fonctionnalites">
    <div class="wrap">

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-coach-chat.png" alt="Discussion avec le coach IA" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Coach IA conversationnel</span>
          <h3>Pose tes questions par texte ou voix, en temps réel.</h3>
          <p>Adapte ton entraînement, demande un conseil nutrition ou un coup de motivation — ton coach répond instantanément, dans ta langue.</p>
          <div class="feature-tags"><span>TEXTE & VOIX</span><span>MULTILINGUE</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-library.png" alt="Bibliothèque d'exercices vidéo" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Bibliothèque d'exercices</span>
          <h3>Plus de 150 exercices vidéo, filtrables par muscle et niveau.</h3>
          <p>Chaque mouvement est démontré en vidéo HD avec des instructions claires, pour progresser sans te blesser, même sans coach en salle.</p>
          <div class="feature-tags"><span>150+ VIDÉOS</span><span>FILTRES PAR MUSCLE</span></div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-progress.png" alt="Analyse graphique des progrès et calories" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Suivi détaillé</span>
          <h3>Visualise tes calories, ta fréquence cardiaque et ta progression.</h3>
          <p>Un graphique clair de ton évolution, jour après jour, pour rester motivé et ajuster ton programme au bon moment.</p>
          <div class="feature-tags"><span>CALORIES</span><span>FRÉQUENCE CARDIAQUE</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-schedule.png" alt="Gestion des entraînements et programmes" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Programmes & planning</span>
          <h3>Gère tes séances de la semaine, sans y penser.</h3>
          <p>Musculation, cardio, running : retrouve toutes tes séances passées et à venir, avec la possibilité de les refaire en un tap.</p>
          <div class="feature-tags"><span>PLANNING HEBDO</span><span>HISTORIQUE</span></div>
        </div>
      </div>

    </div>
  </section>

  <section class="band-gradient">
    <div class="wrap">
      <span class="eyebrow">Adapté à ta culture</span>
      <h2>Un coach qui comprend le Ramadan, tes habitudes et ton rythme de vie.</h2>
      <p>Les programmes s'ajustent aux périodes de jeûne, aux fêtes locales et à la saisonnalité — pas un simple copier-coller de programme générique.</p>
    </div>
  </section>

  <section class="price-section" id="tarif">
    <span class="eyebrow">Tarif</span>
    <h2 style="margin-top:10px;">Choisissez la durée qui vous convient.</h2>
    <div class="price-card">
      <div class="eyebrow">MARCO — AI Fitness Coach</div>
      <p class="price-hint">Cliquez sur une licence pour ouvrir directement le paiement correspondant.</p>

      <div class="tier-list">
        {tiers.map((tier) => (
          <a
            class={`tier-row ${tier.featured ? "featured" : ""}`}
            href={`${paymentUrl}?variant=${encodeURIComponent(tier.variant)}`}
            data-gumroad-overlay-checkout="true"
          >
            <div class="tier-name">
              {tier.name}
              {tier.badge && <span class="tier-badge">{tier.badge}</span>}
            </div>
            <div class="tier-right">
              <div class="tier-price">{tier.price}</div>
              <div class="tier-arrow">→</div>
            </div>
          </a>
        ))}
      </div>

      <ul>
        <li>Onboarding intelligent personnalisé</li>
        <li>Coach IA conversationnel (texte & voix)</li>
        <li>150+ exercices vidéo HD</li>
        <li>Mode hors-ligne</li>
        <li>Adaptation culturelle & Ramadan</li>
      </ul>
    </div>
  </section>

  <section class="guarantee" id="garantie">
    <div class="wrap">
      <div class="guarantee-box">
        <span class="eyebrow">Garantie</span>
        <h2>100% remboursé, sans question posée.</h2>
        <p>Si l'application ne t'aide pas à progresser physiquement, tu es intégralement remboursé, sans justification à donner.</p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="wrap">
      <span class="eyebrow" style="color:#5E6E92">Prêt à commencer ?</span>
      <h2>Ton salon devient ta salle de sport, dès aujourd'hui.</h2>
      <p>Télécharge MARCO et lance ta première séance en quelques minutes.</p>
      <a class="btn btn-primary" href={paymentUrl} data-gumroad-overlay-checkout="true">Télécharger MARCO</a>
      <div class="lang-row">DISPONIBLE EN FRANÇAIS · ENGLISH · العربية · ESPAÑOL</div>
    </div>
  </section>

  <footer>
    <div class="wrap">© 2026 AGH Data Agency Holding — MARCO. Tous droits réservés.</div>
  </footer>

  <!-- Script du prestataire de paiement : détecte les liens pointant vers le domaine de paiement et ouvre le paiement en pop-up.
       is:inline est OBLIGATOIRE : sans ça, Astro bundle ce script externe via Vite, ce qui provoque une erreur CORS au chargement. -->
  <script src="https://gumroad.com/js/gumroad.js" is:inline></script>

</body>
</html>