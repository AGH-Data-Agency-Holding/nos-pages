---
const price = "26,22 €";
const gumroadUrl = "https://aghhol.gumroad.com/l/Stories-of-Prophets-ai";
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Qisas AI — Histoire des prophètes, 100% hors-ligne pour vos enfants</title>
  <meta name="description" content="Qisas AI (Stories of Prophets) : le compagnon islamique intelligent et 100% hors-ligne pour apprendre l'histoire des prophètes à vos enfants, sans publicité ni distraction internet." />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Karla:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="wrap header-inner">
      <a href="#top" class="brand">
        <img src="/images/logo.png" alt="Qisas AI" class="brand-mark" />
        <span class="brand-name">Qisas <em>AI</em></span>
      </a>
      <nav class="nav">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#parcours">Comment ça marche</a>
        <a href="#tarif">Tarif</a>
      </nav>
      <a href={gumroadUrl} class="btn btn-primary btn-small" target="_blank" rel="noopener">Essayer — {price}</a>
    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="hero">
      <div class="ornament ornament-left" aria-hidden="true"></div>
      <div class="ornament ornament-right" aria-hidden="true"></div>
      <div class="wrap hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Compagnon islamique pour enfants · 100% hors-ligne</p>
          <h1>L'histoire des<br/><span class="ink">prophètes</span>,<br/>sans écran de trop.</h1>
          <p class="hero-sub">
            Qisas AI transforme les récits coraniques en aventures simples et captivantes pour vos enfants — dans un environnement 100% sûr, sans publicité, sans internet requis, même en mode avion.
          </p>
          <div class="hero-ctas">
            <a href={gumroadUrl} class="btn btn-primary" target="_blank" rel="noopener">Télécharger Qisas AI</a>
            <a href="#fonctionnalites" class="btn btn-ghost">Découvrir l'application</a>
          </div>
          <p class="hero-microcopy">Disponible en français, anglais, arabe et espagnol · Garantie de remboursement de 6 mois</p>
        </div>
        <div class="hero-visual">
          <img src="/images/phone_home.png" alt="Écran d'accueil de l'application Qisas AI" class="hero-phone" />
        </div>
      </div>
    </section>

    <!-- STATS BAND -->
    <section class="stats-band">
      <div class="wrap stats-inner">
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">fonctionne hors-ligne, y compris l'IA</span>
        </div>
        <div class="stat">
          <span class="stat-num">0</span>
          <span class="stat-label">publicité, aucune distraction internet</span>
        </div>
        <div class="stat">
          <span class="stat-num">4</span>
          <span class="stat-label">langues disponibles : FR, EN, AR, ES</span>
        </div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">Garantie de remboursement de 6 mois</span>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="fonctionnalites" class="features">
      <div class="wrap">
        <p class="eyebrow center">Fonctionnalités clés</p>
        <h2 class="section-title center">Une bibliothèque de sagesse, pensée pour les petites mains</h2>
      </div>

      <!-- Feature 1: Home / Kids mode -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Récits adaptés aux enfants</span>
          <h3>Des histoires complexes, simplifiées avec soin</h3>
          <p>Les récits des prophètes sont transformés en aventures faciles à comprendre pour les plus jeunes, avec un Mode Enfant dédié : histoires ludiques et petits quiz pensés pour leur âge.</p>
          <ul class="feature-list">
            <li>Mode Enfant avec histoires et quiz amusants</li>
            <li>Verset du jour avec contexte et enseignement</li>
            <li>Histoires recommandées à écouter ou à lire</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/tablet_home.png" alt="Accueil de l'application Qisas AI sur tablette" loading="lazy" />
        </div>
      </div>

      <!-- Feature 2: Offline AI -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">IA 100% hors-ligne</span>
          <h3>Résumés intelligents, même en mode avion</h3>
          <p>Notre assistant IA intégré fonctionne entièrement hors-ligne : il génère des résumés clairs et des mini-quiz sans jamais avoir besoin de Wi-Fi. Vos enfants apprennent, concentrés, sans notification ni distraction.</p>
          <ul class="feature-list">
            <li>Assistant IA disponible sans connexion internet</li>
            <li>Résumés et mini-quiz générés automatiquement</li>
            <li>Zéro publicité, environnement 100% sécurisé</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_summary.png" alt="Résumé d'une histoire de prophète dans Qisas AI" loading="lazy" />
        </div>
      </div>

      <!-- Feature 3: Audio -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Écoute audio</span>
          <h3>Le rituel du soir, prêt en un tap</h3>
          <p>Chaque histoire peut être écoutée comme un livre audio, chapitre par chapitre, avec téléchargement pour une écoute hors-ligne — parfait pour accompagner le coucher de votre enfant.</p>
          <ul class="feature-list">
            <li>Lecture audio chapitrée de chaque histoire</li>
            <li>Téléchargement pour écoute sans connexion</li>
            <li>Plusieurs langues audio disponibles</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_audio.png" alt="Lecteur audio d'une histoire dans Qisas AI" loading="lazy" />
        </div>
      </div>

      <!-- Feature 4: Bookmarks -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Favoris & suivi</span>
          <h3>Retrouvez facilement les histoires préférées</h3>
          <p>Enregistrez les récits marquants pour les relire ou les réécouter — pratique pour construire une vraie routine de lecture du soir, sans jamais perdre le fil de l'histoire en cours.</p>
          <ul class="feature-list">
            <li>Liste de favoris pour les histoires et les questions</li>
            <li>Reprise automatique là où vous vous étiez arrêté</li>
            <li>Organisation par prophète et par chapitre</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_bookmarks.png" alt="Liste des favoris dans Qisas AI" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- CALLOUT BAND -->
    <section class="callout">
      <div class="wrap callout-inner">
        <h2>La tranquillité d'esprit des parents, la curiosité des enfants</h2>
        <p>Pas d'écran perdu dans des vidéos sans fin, pas de publicité inappropriée : juste des histoires vraies, racontées avec bienveillance, accessibles partout — même sans réseau.</p>
      </div>
    </section>

    <!-- PARCOURS / HOW IT WORKS -->
    <section id="parcours" class="journey">
      <div class="wrap">
        <p class="eyebrow center">Comment ça marche</p>
        <h2 class="section-title center">De l'installation au rituel du soir</h2>
        <div class="journey-grid">
          <div class="journey-card">
            <span class="journey-mark">Étape 1</span>
            <h4>Installez, sans compte requis</h4>
            <p>Téléchargez Qisas AI et commencez immédiatement — aucune connexion internet nécessaire pour explorer les histoires.</p>
          </div>
          <div class="journey-card">
            <span class="journey-mark">Étape 2</span>
            <h4>Choisissez une histoire ou le Mode Enfant</h4>
            <p>Parcourez les récits des prophètes ou laissez votre enfant explorer en autonomie grâce à l'interface pensée pour les petites mains.</p>
          </div>
          <div class="journey-card">
            <span class="journey-mark">Étape 3</span>
            <h4>Lisez, écoutez ou laissez l'IA résumer</h4>
            <p>Texte, audio ou résumé intelligent généré hors-ligne : chacun apprend à son rythme et selon son mode préféré.</p>
          </div>
          <div class="journey-card">
            <span class="journey-mark">Étape 4</span>
            <h4>Enregistrez vos favoris pour le soir</h4>
            <p>Marquez les histoires préférées pour en faire un vrai rituel de coucher, sans jamais perdre le fil.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section id="tarif" class="pricing">
      <div class="wrap pricing-inner">
        <div class="price-card">
          <p class="price-amount">Licence d'un mois</p>
          <p class="price">5,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 3 mois</p>
          <p class="price">14,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 6 mois</p>
          <p class="price">29,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 12 mois</p>
          <p class="price">44,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Durée de vie</p>
          <p class="price">129,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
      

    <!-- GUARANTEE -->
    <section class="guarantee">
      <div class="wrap guarantee-inner">
        <div class="guarantee-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" width="40" height="40">
            <path d="M24 4 L42 11 V22 C42 33 34.5 41.5 24 44 C13.5 41.5 6 33 6 22 V11 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M16 24 L21.5 29.5 L33 17" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h3>Garantie de remboursement de 6 mois</h3>
          <p>Garantie de remboursement de 6 mois.</p>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="wrap final-cta-inner">
        <h2>Offrez à votre enfant une bibliothèque<br/>de sagesse, partout où vous allez.</h2>
        <p>Sans Wi-Fi, sans publicité, sans compromis sur les valeurs que vous voulez transmettre.</p>
        <a href={gumroadUrl} class="btn btn-light" target="_blank" rel="noopener">Commencer maintenant — {price}</a>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <img src="/images/logo.png" alt="Qisas AI" class="brand-mark" />
        <span class="brand-name">Qisas <em>AI</em></span>
      </div>
      <p class="footer-note">Qisas AI est un outil pédagogique complémentaire et ne remplace pas l'enseignement religieux dispensé par un parent, un imam ou un établissement compétent.</p>
      <p class="footer-copy">© {new Date().getFullYear()} AGH Data Agency Holding SA. Tous droits réservés.</p>
    </div>
  </footer>

  <style>
    :root {
      --ink: #14231B;
      --green: #0B4423;
      --green-deep: #062B15;
      --gold: #C89A4A;
      --gold-light: #FFB000;
      --cream: #FBF7EE;
      --paper: #FFFFFF;
      --slate: #5B6559;
      --line: #E6E0D0;
      --radius: 18px;
      --shadow: 0 12px 32px -12px rgba(11, 68, 35, 0.22);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Karla', -apple-system, sans-serif;
      color: var(--ink);
      background: var(--cream);
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4 {
      font-family: 'Cormorant Garamond', serif;
      margin: 0;
      line-height: 1.1;
      color: var(--ink);
    }
    p { margin: 0; color: var(--slate); line-height: 1.65; }
    a { text-decoration: none; color: inherit; }
    ul { margin: 0; padding: 0; list-style: none; }
    img { max-width: 100%; display: block; }
    em { font-style: italic; color: var(--gold); }

    .wrap {
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 28px;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 28px;
      border-radius: 999px;
      font-family: 'Karla', sans-serif;
      font-weight: 700;
      font-size: 0.96rem;
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--green);
      color: #fff;
      box-shadow: 0 8px 20px -8px rgba(11, 68, 35, 0.55);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 26px -8px rgba(11, 68, 35, 0.6); }
    .btn-small { padding: 10px 20px; font-size: 0.86rem; }
    .btn-ghost {
      border: 1.5px solid var(--line);
      color: var(--ink);
      background: transparent;
    }
    .btn-ghost:hover { border-color: var(--green); background: rgba(11,68,35,0.05); }
    .btn-full { width: 100%; margin-top: 22px; }
    .btn-light {
      background: var(--gold-light);
      color: var(--green-deep);
      box-shadow: 0 8px 20px -8px rgba(0,0,0,0.35);
    }
    .btn-light:hover { transform: translateY(-2px); }

    /* Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(251, 247, 238, 0.88);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      padding-bottom: 14px;
    }
    .brand { display: flex; align-items: center; gap: 10px; }
    .brand-mark { width: 34px; height: 34px; object-fit: contain; border-radius: 50%; }
    .brand-name { font-family: 'Cormorant Garamond', serif; font-weight: 700; font-size: 1.3rem; }
    .nav { display: flex; gap: 30px; }
    .nav a { font-size: 0.92rem; font-weight: 600; color: var(--slate); }
    .nav a:hover { color: var(--green); }

    /* Hero */
    .hero { position: relative; padding: 76px 0 40px; overflow: hidden; }
    .ornament {
      position: absolute;
      top: -60px;
      width: 260px;
      height: 260px;
      border: 1px solid rgba(200, 154, 74, 0.3);
      border-radius: 50%;
      pointer-events: none;
    }
    .ornament::before {
      content: "";
      position: absolute;
      inset: 22px;
      border: 1px solid rgba(200, 154, 74, 0.22);
      border-radius: 50%;
    }
    .ornament-left { left: -130px; }
    .ornament-right { right: -130px; top: 120px; }

    .hero-inner {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 48px;
      align-items: center;
      position: relative;
      z-index: 1;
    }
    .eyebrow {
      font-family: 'Karla', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
      display: block;
    }
    .eyebrow.center { text-align: center; }
    h1 { font-size: clamp(2.6rem, 4.4vw, 3.7rem); font-weight: 700; }
    h1 .ink { color: var(--green); font-style: italic; }
    .hero-sub {
      margin-top: 22px;
      font-size: 1.1rem;
      max-width: 480px;
    }
    .hero-ctas { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
    .hero-microcopy {
      margin-top: 18px;
      font-size: 0.84rem;
      color: #8B9186;
    }

    .hero-visual { display: flex; justify-content: center; }
    .hero-phone {
      width: 100%;
      max-width: 320px;
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    /* Stats band */
    .stats-band {
      background: var(--green-deep);
      padding: 40px 0;
    }
    .stats-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .stat { text-align: center; color: #fff; }
    .stat-num {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: 2.4rem;
      color: var(--gold-light);
    }
    .stat-label {
      display: block;
      margin-top: 6px;
      font-size: 0.84rem;
      color: #C9D3C6;
      max-width: 200px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Features */
    .features { padding: 90px 0 30px; }
    .section-title {
      font-size: clamp(1.8rem, 3.2vw, 2.5rem);
      font-weight: 700;
      max-width: 660px;
      margin: 10px auto 0;
    }
    .section-title.center { text-align: center; margin-left: auto; margin-right: auto; }

    .feature-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: center;
      padding: 64px 0;
      border-bottom: 1px solid var(--line);
    }
    .feature-row:last-child { border-bottom: none; }
    .feature-row.reverse .feature-text { order: 2; }
    .feature-row.reverse .feature-image { order: 1; }

    .feature-tag {
      display: inline-block;
      font-family: 'Karla', sans-serif;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }
    .feature-text h3 {
      font-size: 1.85rem;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .feature-text > p { font-size: 1.02rem; margin-bottom: 20px; }
    .feature-list li {
      position: relative;
      padding-left: 26px;
      margin-bottom: 12px;
      font-size: 0.96rem;
      color: var(--slate);
    }
    .feature-list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--green);
    }
    .feature-image img {
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    /* Callout */
    .callout {
      background: var(--green);
      padding: 70px 0;
      margin: 40px 0;
    }
    .callout-inner { max-width: 780px; text-align: center; margin: 0 auto; }
    .callout h2 {
      color: #fff;
      font-size: clamp(1.6rem, 3vw, 2.3rem);
      font-weight: 700;
    }
    .callout p {
      color: #D9E4D5;
      margin-top: 18px;
      font-size: 1.05rem;
      font-family: 'Karla', sans-serif;
    }

    /* Journey */
    .journey { padding: 30px 0 90px; }
    .journey-grid {
      margin-top: 44px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
    .journey-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 28px 22px;
    }
    .journey-mark {
      display: inline-block;
      font-family: 'Karla', sans-serif;
      font-size: 0.74rem;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .journey-card h4 { font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; }
    .journey-card p { font-size: 0.92rem; font-family: 'Karla', sans-serif; }

    /* Pricing */
    .pricing { padding: 30px 0 90px; }
    .pricing-inner { display: flex; justify-content: center; }
    .pricing-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 48px 44px;
      max-width: 460px;
      width: 100%;
      box-shadow: var(--shadow);
      text-align: center;
    }
    .pricing-card h2 { font-size: 1.9rem; margin-top: 6px; }
    .price { margin-top: 20px; }
    .price-amount {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: 3.4rem;
      color: var(--green);
    }
    .price-sub { margin-top: 6px; font-size: 0.86rem; font-family: 'Karla', sans-serif; }
    .pricing-list {
      text-align: left;
      margin-top: 30px;
      border-top: 1px solid var(--line);
      padding-top: 26px;
    }
    .pricing-list li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 14px;
      font-size: 0.95rem;
      color: var(--ink);
      font-family: 'Karla', sans-serif;
    }
    .pricing-list li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--green);
      font-weight: 700;
    }

    /* Guarantee */
    .guarantee { padding: 0 0 90px; }
    .guarantee-inner {
      display: flex;
      align-items: center;
      gap: 26px;
      background: #EEF2E9;
      border-radius: var(--radius);
      padding: 34px 40px;
      max-width: 780px;
      margin: 0 auto;
    }
    .guarantee-icon { color: var(--green); flex-shrink: 0; }
