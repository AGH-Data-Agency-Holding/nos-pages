---
const price = "26,22 €";
const gumroadUrl = "https://aghhol.gumroad.com/l/salat-hajj-ai";
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Salat & Hajj AI — Votre compagnon spirituel intelligent</title>
  <meta name="description" content="Salat & Hajj AI : rappels de prière intelligents adaptés à votre Madhab, simulation 3D/RA du Hajj et de la Omra, Cheikh virtuel IA disponible 24/7, calculatrice de Zakat. 100% hors-ligne." />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="wrap header-inner">
      <a href="#top" class="brand">
        <img src="/images/logo.png" alt="Salat & Hajj AI" class="brand-mark" />
        <span class="brand-name">Salat & Hajj <em>AI</em></span>
      </a>
      <nav class="nav">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#hajj">Guide du Hajj</a>
        <a href="#tarif">Tarif</a>
      </nav>
      <a href={gumroadUrl} class="btn btn-primary btn-small" target="_blank" rel="noopener">Essayer — {price}</a>
    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="hero">
      <div class="wrap hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Compagnon spirituel intelligent</p>
          <h1>Votre foi, <span class="ink">organisée</span><br/>et accompagnée par l'IA.</h1>
          <p class="hero-sub">
            Salat & Hajj AI apprend vos habitudes pour vous rappeler chaque prière au bon moment, selon votre fuseau horaire et votre Madhab — et vous accompagne pas à pas dans la préparation du Hajj et de la Omra.
          </p>
          <div class="hero-ctas">
            <a href={gumroadUrl} class="btn btn-primary" target="_blank" rel="noopener">Télécharger l'application</a>
            <a href="#fonctionnalites" class="btn btn-ghost">Découvrir les fonctionnalités</a>
          </div>
          <p class="hero-microcopy">Compatible Hanafi, Maliki, Shafi'i et Hanbali · 100% hors-ligne</p>
        </div>
        <div class="hero-visual">
          <img src="/images/phone_home_straight.png" alt="Écran d'accueil de Salat & Hajj AI" class="hero-phone" />
        </div>
      </div>
    </section>

    <!-- STATS BAND -->
    <section class="stats-band">
      <div class="wrap stats-inner">
        <div class="stat">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Cheikh virtuel IA pour vos questions de Fiqh</span>
        </div>
        <div class="stat">
          <span class="stat-num">4</span>
          <span class="stat-label">Madhabs pris en charge : Hanafi, Maliki, Shafi'i, Hanbali</span>
        </div>
        <div class="stat">
          <span class="stat-num">3D/RA</span>
          <span class="stat-label">simulation immersive de Mina et Arafat</span>
        </div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">fonctionne hors-ligne</span>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="fonctionnalites" class="features">
      <div class="wrap">
        <p class="eyebrow center">Fonctionnalités clés</p>
        <h2 class="section-title center">Un compagnon complet pour votre pratique quotidienne</h2>
      </div>

      <!-- Feature 1: Prayer tracking -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Rappels de prière intelligents</span>
          <h3>Ne manquez plus jamais une prière</h3>
          <p>L'application apprend vos habitudes quotidiennes pour envoyer des rappels adaptatifs, entièrement personnalisés selon votre fuseau horaire et votre Madhab préféré. Cochez chaque prière accomplie et suivez votre régularité au fil des jours.</p>
          <ul class="feature-list">
            <li>Horaires de prière précis (Fajr, Dhuhr, Asr, Maghrib, Isha)</li>
            <li>Suivi hebdomadaire de votre régularité</li>
            <li>Direction de la Qibla et rappels personnalisés</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_salat_checklist.png" alt="Suivi des prières quotidiennes dans Salat & Hajj AI" loading="lazy" />
        </div>
      </div>

      <!-- Feature 2: Baraka AI -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Cheikh virtuel IA</span>
          <h3>Une réponse à vos questions, à toute heure</h3>
          <p>Baraka AI, votre assistant islamique quotidien, répond à vos questions de Fiqh 24h/24 — que ce soit sur le Wudu, les duas contre l'anxiété, ou toute autre interrogation religieuse du quotidien.</p>
          <ul class="feature-list">
            <li>Assistant IA disponible en permanence</li>
            <li>Réponses basées sur les sources islamiques reconnues</li>
            <li>Suggestions rapides : duas, rituels, questions fréquentes</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/tablet_baraka_ai.png" alt="Baraka AI, l'assistant islamique de Salat & Hajj AI" loading="lazy" />
        </div>
      </div>

      <!-- Feature 3: Hajj Guide -->
      <div class="feature-row wrap" id="hajj">
        <div class="feature-text">
          <span class="feature-tag">Guide du Hajj & de la Omra</span>
          <h3>Chaque rituel expliqué, étape par étape</h3>
          <p>Préparez votre pèlerinage avec un guide complet : de l'Ihram et l'intention jusqu'au Tawaf Al-Ifadah, chaque étape est détaillée avec des simulations immersives en 3D et réalité augmentée des lieux saints comme Mina et Arafat.</p>
          <ul class="feature-list">
            <li>Check-list complète du Hajj et de la Omra</li>
            <li>Simulations 3D/RA de Mina, Arafat et Muzdalifah</li>
            <li>Suivi de votre progression, étape par étape</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_hajj_guide.png" alt="Guide étape par étape du Hajj dans Salat & Hajj AI" loading="lazy" />
        </div>
      </div>

      <!-- Feature 4: Gamification -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Progression & motivation</span>
          <h3>Un avatar qui évolue avec votre engagement</h3>
          <p>Votre avatar 3D personnel évolue à mesure que vous progressez dans votre pratique. Débloquez des badges, suivez vos séries de prières accomplies, et restez motivé jour après jour grâce à une préparation ludique du Ramadan et du Hajj.</p>
          <ul class="feature-list">
            <li>Avatar 3D personnel évolutif</li>
            <li>Badges et défis : première prière, séries de 5 jours, Ramadan Ready</li>
            <li>Calculatrice intégrée pour gérer votre Zakat</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/tablet_home.png" alt="Progression et badges dans Salat & Hajj AI" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- CALLOUT -->
    <section class="callout">
      <div class="wrap callout-inner">
        <h2>Votre compagnon spirituel, où que vous soyez</h2>
        <p>Suivez vos prières, préparez le Hajj et grandissez spirituellement avec l'IA — une application pensée pour s'adapter à votre Madhab, votre langue et votre quotidien.</p>
      </div>
    </section>

    <!-- PRICING -->
    <section id="tarif" class="pricing">
      <div class="wrap pricing-inner">
        <div class="price-card">
          <p class="price-amount">Licence d'un mois</p>
          <p class="price">26,22 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 3 mois</p>
          <p class="price">52,45 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 6 mois</p>
          <p class="price">104,91 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 12 mois</p>
          <p class="price">174,86 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Durée de vie</p>
          <p class="price">349,73 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
      

    <!-- GUARANTEE -->
    <section class="guarantee">
      <div class="wrap guarantee-inner">
        <div class="guarantee-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" width="40" height="40">
            <path d="M24 4 L42 11 V22 C42 33 34.5 41.5 24 44 C13.5 41.5 6 33 6 22 V11 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M16 24 L21.5 29.5 L33 17" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h3>Livraison instantanée par Gumroad</h3>
          <p>Votre achat est traité de façon sécurisée sur Gumroad. Vous recevez votre accès immédiatement après le paiement, sans compte à créer sur un store tiers.</p>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="wrap final-cta-inner">
        <h2>Organisez votre vie spirituelle<br/>dès aujourd'hui.</h2>
        <p>Prières, Hajj, Zakat et questions de Fiqh : tout dans une seule application, à votre rythme.</p>
        <a href={gumroadUrl} class="btn btn-light" target="_blank" rel="noopener">Commencer maintenant — {price}</a>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <img src="/images/logo.png" alt="Salat & Hajj AI" class="brand-mark" />
        <span class="brand-name">Salat & Hajj <em>AI</em></span>
      </div>
      <p class="footer-note">Salat & Hajj AI est un outil d'accompagnement et ne remplace pas l'avis d'un savant qualifié pour les questions de Fiqh complexes.</p>
      <p class="footer-copy">© {new Date().getFullYear()} AGH Data Agency Holding SA. Tous droits réservés.</p>
    </div>
  </footer>

  <style>
    :root {
      --ink: #0D211F;
      --green: #17A968;
      --green-deep: #0B6B44;
      --gold: #E8B93B;
      --cream: #FAF9F5;
      --paper: #FFFFFF;
      --slate: #52625E;
      --line: #E3E7E2;
      --radius: 18px;
      --shadow: 0 12px 32px -12px rgba(13, 33, 31, 0.22);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, sans-serif;
      color: var(--ink);
      background: var(--cream);
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      margin: 0;
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--ink);
    }
    p { margin: 0; color: var(--slate); line-height: 1.65; }
    a { text-decoration: none; color: inherit; }
    ul { margin: 0; padding: 0; list-style: none; }
    img { max-width: 100%; display: block; }
    em { font-style: normal; color: var(--gold); }

    .wrap {
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 28px;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 28px;
      border-radius: 999px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 600;
      font-size: 0.96rem;
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--green);
      color: #fff;
      box-shadow: 0 8px 20px -8px rgba(23, 169, 104, 0.55);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 26px -8px rgba(23, 169, 104, 0.6); }
    .btn-small { padding: 10px 20px; font-size: 0.86rem; }
    .btn-ghost {
      border: 1.5px solid var(--line);
      color: var(--ink);
      background: transparent;
    }
    .btn-ghost:hover { border-color: var(--green); background: rgba(23,169,104,0.05); }
    .btn-full { width: 100%; margin-top: 22px; }
    .btn-light {
      background: var(--gold);
      color: var(--ink);
      box-shadow: 0 8px 20px -8px rgba(0,0,0,0.35);
    }
    .btn-light:hover { transform: translateY(-2px); }

    /* Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(250, 249, 245, 0.88);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      padding-bottom: 14px;
    }
    .brand { display: flex; align-items: center; gap: 10px; }
    .brand-mark { width: 32px; height: 32px; object-fit: contain; }
    .brand-name { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 1.05rem; }
    .nav { display: flex; gap: 30px; }
    .nav a { font-size: 0.92rem; font-weight: 500; color: var(--slate); }
    .nav a:hover { color: var(--green); }

    /* Hero */
    .hero { padding: 76px 0 40px; overflow: hidden; }
    .hero-inner {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 48px;
      align-items: center;
    }
    .eyebrow {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--green-deep);
      margin-bottom: 14px;
      display: block;
    }
    .eyebrow.center { text-align: center; }
    h1 { font-size: clamp(2.4rem, 4.2vw, 3.4rem); font-weight: 800; }
    h1 .ink { color: var(--green); }
    .hero-sub {
      margin-top: 22px;
      font-size: 1.1rem;
      max-width: 480px;
    }
    .hero-ctas { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
    .hero-microcopy {
      margin-top: 18px;
      font-size: 0.85rem;
      color: #8A968F;
    }

    .hero-visual { display: flex; justify-content: center; }
    .hero-phone {
      width: 100%;
      max-width: 300px;
    }

    /* Stats band */
    .stats-band {
      background: var(--ink);
      padding: 40px 0;
    }
    .stats-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .stat { text-align: center; color: #fff; }
    .stat-num {
      display: block;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 2.2rem;
      color: var(--gold);
    }
    .stat-label {
      display: block;
      margin-top: 6px;
      font-size: 0.85rem;
      color: #B9C4BF;
      max-width: 200px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Features */
    .features { padding: 90px 0 30px; }
    .section-title {
      font-size: clamp(1.7rem, 3vw, 2.3rem);
      font-weight: 700;
      max-width: 640px;
      margin: 10px auto 0;
    }
    .section-title.center { text-align: center; margin-left: auto; margin-right: auto; }

    .feature-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: center;
      padding: 64px 0;
      border-bottom: 1px solid var(--line);
    }
    .feature-row:last-child { border-bottom: none; }
    .feature-row.reverse .feature-text { order: 2; }
    .feature-row.reverse .feature-image { order: 1; }

    .feature-tag {
      display: inline-block;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--green-deep);
      margin-bottom: 12px;
    }
    .feature-text h3 {
      font-size: 1.65rem;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .feature-text > p { font-size: 1.02rem; margin-bottom: 20px; }
    .feature-list li {
      position: relative;
      padding-left: 26px;
      margin-bottom: 12px;
      font-size: 0.96rem;
      color: var(--slate);
    }
    .feature-list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--green);
    }
    .feature-image { display: flex; justify-content: center; }
    .feature-image img {
      max-width: 320px;
    }

    /* Callout */
    .callout {
      background: var(--green-deep);
      padding: 70px 0;
      margin: 40px 0;
    }
    .callout-inner { max-width: 780px; text-align: center; margin: 0 auto; }
    .callout h2 {
      color: #fff;
      font-size: clamp(1.6rem, 3vw, 2.3rem);
      font-weight: 700;
    }
    .callout p {
      color: #D3E9DE;
      margin-top: 18px;
      font-size: 1.05rem;
    }

    /* Pricing */
    .pricing { padding: 30px 0 90px; }
    .pricing-inner { display: flex; justify-content: center; }
    .pricing-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 48px 44px;
      max-width: 460px;
      width: 100%;
      box-shadow: var(--shadow);
      text-align: center;
    }
    .pricing-card h2 { font-size: 1.6rem; margin-top: 6px; }
    .price { margin-top: 20px; }
    .price-amount {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 3.2rem;
      color: var(--green);
    }
    .price-sub { margin-top: 6px; font-size: 0.88rem; }
    .pricing-list {
      text-align: left;
      margin-top: 30px;
      border-top: 1px solid var(--line);
      padding-top: 26px;
    }
    .pricing-list li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 14px;
      font-size: 0.95rem;
      color: var(--ink);
    }
    .pricing-list li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--green);
      font-weight: 700;
    }

    /* Guarantee */
    .guarantee { padding: 0 0 90px; }
    .guarantee-inner {
      display: flex;
      align-items: center;
      gap: 26px;
      background: #EEF3EF;
      border-radius: var(--radius);
      padding: 34px 40px;
      max-width: 780px;
      margin: 0 auto;
    }
    .guarantee-icon { color: var(--green-deep); flex-shrink: 0; }
    .guarantee h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; }
    .guarantee p { font-size: 0.92rem; }

    /* Final CTA */
    .final-cta {
      background: var(--ink);
      padding: 90px 0;
    }
    .final-cta-inner { text-align: center; max-width: 640px; margin: 0 auto; }
    .final-cta h2 { color: #fff; font-size: clamp(1.7rem, 3vw, 2.4rem); }
    .final-cta p { color: #B9C4BF; margin-top: 18px; font-size: 1.05rem; }
    .final-cta .btn { margin-top: 32px; }

    /* Footer */
    .site-footer { padding: 44px 0; }
    .footer-inner { text-align: center; }
    .footer-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .footer-note {
      font-size: 0.82rem;
      max-width: 540px;
      margin: 0 auto 10px;
      color: #8A968F;
    }
    .footer-copy { font-size: 0.8rem; color: #9FAAA5; }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-visual { order: -1; margin-bottom: 10px; }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
      .feature-row { grid-template-columns: 1fr; gap: 30px; padding: 44px 0; }
      .feature-row.reverse .feature-text,
      .feature-row.reverse .feature-image { order: initial; }
      .nav { display: none; }
      .guarantee-inner { flex-direction: column; text-align: center; }
    }
    @media (max-width: 560px) {
      .stats-inner { grid-template-columns: 1fr 1fr; }
      .pricing-card { padding: 36px 26px; }
    }
  </style>
</body>
</html>
