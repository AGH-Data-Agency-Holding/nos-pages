---
const gumroadUrl = "https://aghhol.gumroad.com/l/Styliste-Dresser-ai";
---
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dresser AI — Ton styliste IA, même sans connexion</title>
  <meta name="description" content="Scanne ta garde-robe, génère des tenues selon la météo et l'occasion, discute avec ton styliste IA 24/7 en plus de 50 langues." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --lavender: #EDE9FB;
      --lilac: #C9BBF5;
      --purple: #7B5FD9;
      --purple-dark: #5A3FB0;
      --pink: #E8829E;
      --ink: #2A1F3D;
      --line: #DCD3F4;
      font-family: Inter, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--lavender); color: var(--ink); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 600; letter-spacing: -0.01em; color: var(--ink); margin: 0; }
    .eyebrow { font-family: "JetBrains Mono", monospace; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--purple-dark); font-weight: 700; }
    a { color: inherit; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; font-size: .95rem; padding: 14px 26px; border-radius: 100px; text-decoration: none; transition: transform .15s ease, box-shadow .15s ease; }
    .btn-primary { background: linear-gradient(120deg, var(--purple), var(--pink)); color: #FBF7FF; box-shadow: 0 8px 22px rgba(123,95,217,.35); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(123,95,217,.42); }
    .btn-ghost { border: 1.5px solid var(--ink); color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--lavender); }

    header { position: sticky; top: 0; z-index: 40; background: rgba(237,233,251,.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; }
    .brand { display: flex; align-items: center; gap: 10px; font-family: "Fraunces", serif; font-weight: 700; font-size: 1.15rem; color: var(--ink); text-decoration: none; }
    .brand svg { width: 30px; height: 30px; }
    .nav-links { display: flex; gap: 28px; font-size: .92rem; font-weight: 500; }
    .nav-links a { text-decoration: none; color: var(--ink); }
    .nav-links a:hover { color: var(--purple); }
    @media (max-width: 780px) { .nav-links { display: none; } }

    .hero { padding: 70px 0 30px; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 44px; align-items: center; }
    @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero h1 { font-size: clamp(2.2rem, 4.2vw, 3.2rem); line-height: 1.08; margin: 14px 0 18px; }
    .hero h1 em { font-style: italic; color: var(--purple); }
    .hero p.lede { font-size: 1.08rem; line-height: 1.6; color: #55486E; max-width: 470px; margin-bottom: 28px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
    .trust-line { font-size: .85rem; color: #55486E; font-family: "JetBrains Mono", monospace; }
    .trust-line strong { color: var(--pink); }
    .hero-visual { display: flex; justify-content: center; position: relative; }
    .glow { position: absolute; width: 380px; height: 380px; border-radius: 50%; background: radial-gradient(circle, rgba(123,95,217,.22), transparent 65%); top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .phone-frame { position: relative; width: 250px; border-radius: 32px; overflow: hidden; box-shadow: 0 30px 60px rgba(90,63,176,.28); border: 6px solid var(--ink); }

    .stat-band { background: var(--ink); color: #ECE6FA; padding: 46px 0; }
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
    @media (max-width: 780px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-grid .num { font-family: "Fraunces", serif; font-size: 2rem; background: linear-gradient(120deg, var(--lilac), var(--pink)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .stat-grid .label { font-size: .76rem; color: #A896C4; font-family: "JetBrains Mono", monospace; letter-spacing: .04em; margin-top: 4px; }

    .feature-section { padding: 100px 0; }
    .feature-row { display: grid; grid-template-columns: .9fr 1.1fr; gap: 54px; align-items: center; margin-bottom: 100px; }
    .feature-row.reverse { grid-template-columns: 1.1fr .9fr; }
    .feature-row.reverse .feature-copy { order: 2; }
    .feature-row.reverse .feature-shot { order: 1; }
    @media (max-width: 860px) {
      .feature-row, .feature-row.reverse { grid-template-columns: 1fr; }
      .feature-row.reverse .feature-copy, .feature-row.reverse .feature-shot { order: unset; }
    }
    .feature-shot { display: flex; justify-content: center; }
    .feature-shot img { width: 100%; max-width: 270px; border-radius: 24px; box-shadow: 0 24px 48px rgba(42,31,61,.18); border: 5px solid #fff; }
    .feature-copy h3 { font-size: 1.6rem; margin: 12px 0 14px; }
    .feature-copy p { color: #55486E; line-height: 1.65; font-size: 1rem; max-width: 420px; }
    .feature-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .feature-tags span { font-family: "JetBrains Mono", monospace; font-size: .7rem; letter-spacing: .03em; background: #fff; color: var(--purple-dark); padding: 6px 12px; border-radius: 100px; border: 1px solid var(--line); }

    .band-gradient { background: linear-gradient(120deg, var(--purple) 0%, var(--pink) 100%); color: #FBF7FF; padding: 60px 0; text-align: center; }
    .band-gradient .eyebrow { color: #F3D9E2; }
    .band-gradient h2 { color: #FBF7FF; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 12px auto 14px; max-width: 640px; }
    .band-gradient p { max-width: 540px; margin: 0 auto; color: #F3E4EC; line-height: 1.6; }

    .price-section { padding: 90px 0; text-align: center; }
    .price-card { max-width: 440px; margin: 40px auto 0; background: #fff; border: 1px solid var(--line); border-radius: 22px; padding: 34px; }
    .price-card .price { font-family: "Fraunces", serif; font-size: 2.6rem; margin: 10px 0 4px; }
    .price-card .price span { font-size: 1rem; font-family: Inter, sans-serif; font-weight: 500; color: #55486E; }
    .price-card ul { list-style: none; padding: 0; margin: 22px 0 26px; text-align: left; }
    .price-card li { padding: 8px 0; font-size: .94rem; border-top: 1px solid var(--line); }
    .price-card li:first-child { border-top: none; }


    .tier-list { display: flex; flex-direction: column; gap: 10px; margin: 24px 0 28px; }
    .tier-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-radius: 14px; border: 1px solid rgba(0,0,0,.08);
      background: #fff;
    }
    .tier-row.featured {
      border: 1.5px solid #7B5FD9; background: #7B5FD910;
      position: relative;
    }
    .tier-name { font-size: .95rem; font-weight: 600; }
    .tier-badge {
      font-family: "JetBrains Mono", monospace; font-size: .62rem; letter-spacing: .04em;
      text-transform: uppercase; color: #7B5FD9; font-weight: 700; display: block; margin-top: 2px;
    }
    .tier-price { font-family: "Fraunces", serif; font-weight: 600; font-size: 1.15rem; color: #E8829E; white-space: nowrap; }

    .guarantee { padding: 0 0 100px; }
    .guarantee-box { background: #fff; border: 1px solid var(--line); border-radius: 24px; padding: 46px; text-align: center; }
    .guarantee-box h2 { font-size: 1.5rem; margin: 10px 0 12px; }
    .guarantee-box p { max-width: 560px; margin: 0 auto; color: var(--ink); line-height: 1.6; }

    .final-cta { background: var(--ink); color: #ECE6FA; padding: 90px 0; text-align: center; }
    .final-cta h2 { color: #FBF7FF; font-size: clamp(1.8rem, 3.2vw, 2.5rem); margin: 10px 0 16px; }
    .final-cta p { color: #A896C4; max-width: 480px; margin: 0 auto 30px; }
    .lang-row { margin-top: 32px; font-family: "JetBrains Mono", monospace; font-size: .78rem; color: #6E5F8C; letter-spacing: .05em; }

    footer { padding: 34px 0; text-align: center; font-size: .85rem; color: #55486E; }
  </style>
</head>
<body>

  <header>
    <div class="wrap nav">
      <a class="brand" href="#top">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 8l4 4 4-4-2 8h-4l-2-8Z" fill="#7B5FD9"/>
          <path d="M16 40c0-8 3-14 8-16 5 2 8 8 8 16H16Z" fill="url(#g1)"/>
          <defs>
            <linearGradient id="g1" x1="16" y1="24" x2="32" y2="40" gradientUnits="userSpaceOnUse">
              <stop stop-color="#7B5FD9"/>
              <stop offset="1" stop-color="#E8829E"/>
            </linearGradient>
          </defs>
        </svg>
        Dresser AI
      </a>
      <nav class="nav-links">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#tarif">Tarif</a>
        <a href="#garantie">Garantie</a>
      </nav>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger</a>
    </div>
  </header>

  <section class="hero" id="top">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">Styliste IA · 50+ langues</span>
        <h1>Fini le dilemme du <em>"qu'est-ce que je mets"</em>, chaque matin.</h1>
        <p class="lede">Dresser AI scanne ta garde-robe, comprend ta morphologie et te propose des tenues adaptées à la météo, à l'occasion et à ton humeur — un vrai styliste, disponible 24/7.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger l'app</a>
          <a class="btn btn-ghost" href="#fonctionnalites">Voir les fonctionnalités</a>
        </div>
        <p class="trust-line">100% remboursé si l'app ne t'aide pas · <strong>réduit le stress matinal de 50%</strong></p>
      </div>
      <div class="hero-visual">
        <div class="glow"></div>
        <div class="phone-frame">
          <img src="/images/screen-home.png" alt="Tableau de bord Dresser AI" />
        </div>
      </div>
    </div>
  </section>

  <section class="stat-band">
    <div class="wrap stat-grid">
      <div>
        <div class="num">85%</div>
        <div class="label">PRÉCISION DU SCAN DE GARDE-ROBE</div>
      </div>
      <div>
        <div class="num">50+</div>
        <div class="label">LANGUES SUPPORTÉES</div>
      </div>
      <div>
        <div class="num">24/7</div>
        <div class="label">STYLISTE IA DISPONIBLE</div>
      </div>
      <div>
        <div class="num">-50%</div>
        <div class="label">DE STRESS MATINAL</div>
      </div>
    </div>
  </section>

  <section class="feature-section" id="fonctionnalites">
    <div class="wrap">

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-generate.png" alt="Génération de tenue avec la garde-robe virtuelle" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Générateur de tenues</span>
          <h3>Compose une tenue à partir de ce que tu possèdes déjà.</h3>
          <p>Mixe vestes, hauts, bas et chaussures de ta propre garde-robe pour découvrir des combinaisons que tu n'aurais jamais imaginées toi-même.</p>
          <div class="feature-tags"><span>MIX & MATCH</span><span>GARDE-ROBE VIRTUELLE</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-ai-stylist.png" alt="Discussion avec le styliste IA" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Styliste IA conversationnel</span>
          <h3>Demande une tenue pour une réunion, une sortie ou un mariage.</h3>
          <p>Décris l'occasion, et le styliste IA te propose instantanément plusieurs looks complets, adaptés à ton style et à la météo du jour.</p>
          <div class="feature-tags"><span>TEXTE & PHOTO</span><span>50+ LANGUES</span></div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-wardrobe-tops.png" alt="Organisation de la garde-robe par catégorie" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Garde-robe organisée</span>
          <h3>Toute ta garde-robe, triée et cataloguée automatiquement.</h3>
          <p>Hauts, bas, robes, chaussures : chaque vêtement scanné est classé pour que tu retrouves tout en un instant, sans jamais fouiller ton placard.</p>
          <div class="feature-tags"><span>SCAN PHOTO</span><span>TRI AUTOMATIQUE</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-wardrobe-shoes.png" alt="Catalogue de chaussures dans la garde-robe" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Mode multiculturelle</span>
          <h3>Des tenues qui respectent tes traditions autant que les tendances.</h3>
          <p>L'IA comprend aussi bien le streetwear moderne que les tenues traditionnelles comme le kaftan ou le sari, pour un style qui te ressemble vraiment.</p>
          <div class="feature-tags"><span>INCLUSIF</span><span>TOUTES MORPHOLOGIES</span></div>
        </div>
      </div>

    </div>
  </section>

  <section class="band-gradient">
    <div class="wrap">
      <span class="eyebrow">Shopping intelligent</span>
      <h2>Achète moins, mais mieux — seulement ce qui complète vraiment ton style.</h2>
      <p>L'assistant shopping compare les prix entre boutiques et t'alerte, pour éviter les achats impulsifs et économiser sur le long terme.</p>
    </div>
  </section>

  <section class="price-section" id="tarif">
    <span class="eyebrow">Tarif</span>
    <h2 style="margin-top:10px;">Un prix simple, pas d'abonnement caché.</h2>
    <div class="price-card">
      <div class="eyebrow">Dresser AI</div>
      <div class="tier-list">
        <div class="tier-row">
          <div class="tier-name">Licence d'un mois</div>
          <div class="tier-price">26,22 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Licence de 3 mois</div>
          <div class="tier-price">52,45 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Licence de 6 mois</div>
          <div class="tier-price">104,91 €</div>
        </div>
        <div class="tier-row featured">
          <div class="tier-name">Licence de 12 mois<span class="tier-badge">Le plus choisi</span></div>
          <div class="tier-price">174,86 €</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Durée de vie</div>
          <div class="tier-price">349,73 €</div>
        </div>
      </div>
      <ul>
        <li>Styliste IA conversationnel 24/7</li>
        <li>Scan de garde-robe (85% de précision)</li>
        <li>Générateur de tenues selon météo & occasion</li>
        <li>Assistant shopping intelligent</li>
        <li>Communauté mode mondiale</li>
      </ul>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="width:100%; justify-content:center;">Télécharger maintenant</a>
    </div>
  </section>

  <section class="guarantee" id="garantie">
    <div class="wrap">
      <div class="guarantee-box">
        <span class="eyebrow">Garantie</span>
        <h2>100% remboursé, sans question posée.</h2>
        <p>Si l'application ne simplifie pas ta routine du matin, tu es intégralement remboursé, sans justification à donner.</p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="wrap">
      <span class="eyebrow" style="color:#6E5F8C">Prêt à révolutionner tes matins ?</span>
      <h2>Ton armoire devient enfin simple à utiliser.</h2>
      <p>Télécharge Dresser AI et scanne ta première tenue dès aujourd'hui.</p>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger Dresser AI</a>
      <div class="lang-row">DISPONIBLE EN FRANÇAIS · ENGLISH · العربية · ESPAÑOL · +47 AUTRES LANGUES</div>
    </div>
  </section>

  <footer>
    <div class="wrap">© 2026 AGH Data Agency Holding — Dresser AI. Tous droits réservés.</div>
  </footer>

</body>
</html>
