---
const price = "7,99 €";
const gumroadUrl = "https://aghhol.gumroad.com/l/bjwrxx";
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vape Stopper — Arrêtez la vape avec un coach IA 24h/24</title>
  <meta name="description" content="Vape Stopper : votre coach IA 24h/24 pour un sevrage progressif, durable et personnalisé de la cigarette électronique. Plan sur 8 à 12 semaines, mode SOS Craving, plus de 30 techniques validées." />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="wrap header-inner">
      <a href="#top" class="brand">
        <img src="/images/logo.png" alt="Vape Stopper" class="brand-mark" />
        <span class="brand-name">Vape Stopper</span>
      </a>
      <nav class="nav">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#parcours">Le parcours</a>
        <a href="#tarif">Tarif</a>
      </nav>
      <a href={gumroadUrl} class="btn btn-primary btn-small" target="_blank" rel="noopener">Commencer — {price}</a>
    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="hero">
      <div class="wrap hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Coach IA de sevrage à la vape</p>
          <h1>Reprenez le contrôle,<br/><span class="ink">une respiration</span><br/>à la fois.</h1>
          <p class="hero-sub">
            Vape Stopper est votre coach IA disponible 24h/24 pour un sevrage progressif et durable de la cigarette électronique — sans culpabilité, avec un plan qui s'adapte à votre corps et à votre culture.
          </p>
          <div class="hero-ctas">
            <a href={gumroadUrl} class="btn btn-primary" target="_blank" rel="noopener">Démarrer mon sevrage</a>
            <a href="#fonctionnalites" class="btn btn-ghost">Voir les fonctionnalités</a>
          </div>
          <p class="hero-microcopy">Application offline-first · Disponible en français, anglais, arabe et espagnol</p>
        </div>
        <div class="hero-visual">
          <div class="breath-rings" aria-hidden="true">
            <span class="ring ring-1"></span>
            <span class="ring ring-2"></span>
            <span class="ring ring-3"></span>
          </div>
          <img src="/images/phone_tracker.png" alt="Suivi de la consommation dans l'application Vape Stopper" class="hero-phone" />
        </div>
      </div>
    </section>

    <!-- STATS BAND -->
    <section class="stats-band">
      <div class="wrap stats-inner">
        <div class="stat">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Coach IA disponible à tout moment</span>
        </div>
        <div class="stat">
          <span class="stat-num">8–12</span>
          <span class="stat-label">semaines de sevrage progressif</span>
        </div>
        <div class="stat">
          <span class="stat-num">30+</span>
          <span class="stat-label">techniques validées (TCC, respiration, pleine conscience)</span>
        </div>
        <div class="stat">
          <span class="stat-num">4</span>
          <span class="stat-label">régions couvertes : Europe, Afrique, Amériques, Asie</span>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="fonctionnalites" class="features">
      <div class="wrap">
        <p class="eyebrow center">Fonctionnalités clés</p>
        <h2 class="section-title center">Tout ce qu'il faut pour tenir, jour après jour</h2>
      </div>

      <!-- Feature 1: Coach IA -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Coach IA anti-craving</span>
          <h3>Un mot suffit à démarrer la conversation</h3>
          <p>Dites simplement comment vous vous sentez — "j'ai envie de vapoter", "je suis stressé" — et votre coach répond aussitôt avec des conseils validés par des experts, dans un ton adapté à votre culture et à votre langue.</p>
          <ul class="feature-list">
            <li>Réponses instantanées, disponibles 24h/24</li>
            <li>Suggestions concrètes : respiration guidée, distraction, rappel de vos motivations</li>
            <li>Scripts culturellement adaptés selon votre région</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_coach.png" alt="Conversation avec le coach IA de Vape Stopper" loading="lazy" />
        </div>
      </div>

      <!-- Feature 2: Tracker -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Suivi & économies</span>
          <h3>Voyez votre progrès — et votre argent économisé</h3>
          <p>Chaque jour sans vapoter est compté, chaque baisse de consommation est visible sur un graphique clair. Vape Stopper calcule automatiquement l'argent que vous économisez, dans votre monnaie locale.</p>
          <ul class="feature-list">
            <li>Journal de consommation et des déclencheurs (triggers)</li>
            <li>Graphique d'évolution sur la semaine</li>
            <li>Compteur de jours sans vape, de réduction en % et d'économies réalisées</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/tablet_tracker.png" alt="Tableau de suivi de progression dans Vape Stopper" loading="lazy" />
        </div>
      </div>

      <!-- Feature 3: SOS -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Mode SOS Craving</span>
          <h3>Pour les envies fortes, une aide immédiate</h3>
          <p>Un accès en un clic à des outils d'urgence, même hors connexion. Respiration guidée, exercices de recentrage et rappel que l'envie va passer — pour tenir bon dans les moments les plus difficiles.</p>
          <ul class="feature-list">
            <li>Fonctionne même hors ligne</li>
            <li>Respiration rythmée guidée sur 1 minute</li>
            <li>Suggestions immédiates : boire un verre d'eau, marcher, écouter un audio apaisant</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_sos.png" alt="Mode SOS Craving de Vape Stopper" loading="lazy" />
        </div>
      </div>

      <!-- Feature 4: Community -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Communautés de soutien</span>
          <h3>Vous n'êtes pas seul dans ce parcours</h3>
          <p>Rejoignez des groupes segmentés par langue, âge et profil pour échanger avec des personnes qui vivent la même chose que vous — un espace bienveillant, sans jugement.</p>
          <ul class="feature-list">
            <li>Fil d'actualité, réussites, questions et groupes thématiques</li>
            <li>Encouragements et soutien entre membres</li>
            <li>Espace modéré : bienveillance et respect avant tout</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/tablet_community.png" alt="Communauté de soutien Vape Stopper" loading="lazy" />
        </div>
      </div>

      <!-- Feature 5: Progressive plan -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Sevrage progressif guidé</span>
          <h3>Un plan qui s'ajuste à votre rythme, pas l'inverse</h3>
          <p>Contrairement aux applications anti-tabac génériques, Vape Stopper gère spécifiquement les dosages de nicotine, les arômes et la gestuelle propres à la vape. Le plan de réduction s'étale sur 8 à 12 semaines et s'adapte dynamiquement à vos réactions pour éviter les rechutes.</p>
          <ul class="feature-list">
            <li>Techniques de thérapie cognitivo-comportementale (TCC) et de pleine conscience</li>
            <li>Objectifs hebdomadaires personnalisés</li>
            <li>Approche "glocale" : contenu adapté à votre pouvoir d'achat et à votre culture</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/tablet_onboarding.png" alt="Démarrage du parcours de sevrage Vape Stopper" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- CALLOUT BAND -->
    <section class="callout">
      <div class="wrap callout-inner">
        <h2>La première appli de sevrage "glocale" — pensée pour votre réalité, partout dans le monde</h2>
        <p>Que vous soyez à Bamako, Paris, Dakar ou ailleurs, Vape Stopper adapte son contenu et son coaching aux pressions sociales, aux habitudes de consommation et aux réalités économiques de votre région.</p>
      </div>
    </section>

    <!-- PARCOURS / HOW IT WORKS -->
    <section id="parcours" class="journey">
      <div class="wrap">
        <p class="eyebrow center">Le parcours</p>
        <h2 class="section-title center">De la première envie au dernier puff</h2>
        <div class="journey-grid">
          <div class="journey-card">
            <span class="journey-mark">Étape 1</span>
            <h4>Vous racontez votre situation</h4>
            <p>Fréquence, déclencheurs, dosage de nicotine — le coach IA construit votre profil de départ.</p>
          </div>
          <div class="journey-card">
            <span class="journey-mark">Étape 2</span>
            <h4>Vous suivez un plan sur 8 à 12 semaines</h4>
            <p>Des objectifs progressifs qui s'ajustent selon vos réactions physiques et mentales, semaine après semaine.</p>
          </div>
          <div class="journey-card">
            <span class="journey-mark">Étape 3</span>
            <h4>Vous tenez bon grâce au mode SOS</h4>
            <p>Dans les moments de forte envie, un accès immédiat à des outils d'urgence, même hors ligne.</p>
          </div>
          <div class="journey-card">
            <span class="journey-mark">Étape 4</span>
            <h4>Vous célébrez chaque victoire</h4>
            <p>Avec le soutien d'une communauté qui comprend exactement ce que vous traversez.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section id="tarif" class="pricing">
      <div class="wrap pricing-inner">
        <div class="price-card">
          <p class="price-amount">Licence d'un mois</p>
          <p class="price">7,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 3 mois</p>
          <p class="price">19,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 6 mois</p>
          <p class="price">39,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 12 mois</p>
          <p class="price">59,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Durée de vie</p>
          <p class="price">129,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
      

    <!-- GUARANTEE -->
    <section class="guarantee">
      <div class="wrap guarantee-inner">
        <div class="guarantee-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" width="40" height="40">
            <path d="M24 4 L42 11 V22 C42 33 34.5 41.5 24 44 C13.5 41.5 6 33 6 22 V11 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M16 24 L21.5 29.5 L33 17" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h3>Livraison instantanée par Gumroad</h3>
          <p>Votre achat est traité de façon sécurisée sur Gumroad. Vous recevez votre accès immédiatement après le paiement, sans compte à créer sur un store tiers.</p>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="wrap final-cta-inner">
        <h2>Votre prochaine cigarette électronique<br/>n'est pas obligatoire.</h2>
        <p>Rejoignez Vape Stopper et commencez votre sevrage aujourd'hui, à votre rythme.</p>
        <a href={gumroadUrl} class="btn btn-light" target="_blank" rel="noopener">Commencer maintenant — {price}</a>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <img src="/images/logo.png" alt="Vape Stopper" class="brand-mark" />
        <span class="brand-name">Vape Stopper</span>
      </div>
      <p class="footer-note">Vape Stopper est un outil d'accompagnement au sevrage et ne remplace pas un avis médical. Consultez un professionnel de santé si besoin.</p>
      <p class="footer-copy">© {new Date().getFullYear()} AGH Data Agency Holding SA. Tous droits réservés.</p>
    </div>
  </footer>

  <style>
    :root {
      --ink: #14213D;
      --navy: #2A497D;
      --navy-light: #4A6FA5;
      --sky: #3FA9C9;
      --coral: #E8604F;
      --cream: #F7F6F2;
      --paper: #FFFFFF;
      --slate: #55627A;
      --line: #E4E2DA;
      --radius: 18px;
      --shadow: 0 12px 32px -12px rgba(20, 33, 61, 0.18);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, sans-serif;
      color: var(--ink);
      background: var(--cream);
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4 {
      font-family: 'Sora', sans-serif;
      margin: 0;
      line-height: 1.12;
      letter-spacing: -0.01em;
      color: var(--ink);
    }
    p { margin: 0; color: var(--slate); line-height: 1.6; }
    a { text-decoration: none; color: inherit; }
    ul { margin: 0; padding: 0; list-style: none; }
    img { max-width: 100%; display: block; }

    .wrap {
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 28px;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 28px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.98rem;
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--navy);
      color: #fff;
      box-shadow: 0 8px 20px -8px rgba(42, 73, 125, 0.55);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 26px -8px rgba(42, 73, 125, 0.6); }
    .btn-small { padding: 10px 20px; font-size: 0.88rem; }
    .btn-ghost {
      border: 1.5px solid var(--line);
      color: var(--ink);
      background: transparent;
    }
    .btn-ghost:hover { border-color: var(--navy); background: rgba(42,73,125,0.05); }
    .btn-full { width: 100%; margin-top: 22px; }
    .btn-light {
      background: #fff;
      color: var(--navy);
      box-shadow: 0 8px 20px -8px rgba(0,0,0,0.3);
    }
    .btn-light:hover { transform: translateY(-2px); }

    /* Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(247, 246, 242, 0.86);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      padding-bottom: 14px;
    }
    .brand { display: flex; align-items: center; gap: 10px; }
    .brand-mark { width: 32px; height: 32px; object-fit: contain; }
    .brand-name { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 1.05rem; }
    .nav { display: flex; gap: 30px; }
    .nav a { font-size: 0.94rem; font-weight: 500; color: var(--slate); }
    .nav a:hover { color: var(--navy); }

    /* Hero */
    .hero { padding: 76px 0 40px; overflow: hidden; }
    .hero-inner {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 48px;
      align-items: center;
    }
    .eyebrow {
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--sky);
      margin-bottom: 14px;
      display: block;
    }
    .eyebrow.center { text-align: center; }
    h1 { font-size: clamp(2.4rem, 4.2vw, 3.4rem); font-weight: 800; }
    h1 .ink { color: var(--navy); }
    .hero-sub {
      margin-top: 22px;
      font-size: 1.1rem;
      max-width: 480px;
    }
    .hero-ctas { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
    .hero-microcopy {
      margin-top: 18px;
      font-size: 0.85rem;
      color: #8792A6;
    }

    .hero-visual {
      position: relative;
      display: flex;
      justify-content: center;
    }
    .hero-phone {
      width: 100%;
      max-width: 340px;
      border-radius: 28px;
      position: relative;
      z-index: 2;
    }
    .breath-rings {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1;
    }
    .ring {
      position: absolute;
      border-radius: 50%;
      border: 1.5px solid rgba(63, 169, 201, 0.35);
      animation: breathe 4.5s ease-in-out infinite;
    }
    .ring-1 { width: 340px; height: 340px; animation-delay: 0s; }
    .ring-2 { width: 440px; height: 440px; animation-delay: 0.6s; }
    .ring-3 { width: 540px; height: 540px; animation-delay: 1.2s; }
    @keyframes breathe {
      0%, 100% { transform: scale(0.94); opacity: 0.35; }
      50% { transform: scale(1.04); opacity: 0.8; }
    }
    @media (prefers-reduced-motion: reduce) {
      .ring { animation: none; }
    }

    /* Stats band */
    .stats-band {
      background: var(--ink);
      padding: 40px 0;
    }
    .stats-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .stat { text-align: center; color: #fff; }
    .stat-num {
      display: block;
      font-family: 'Sora', sans-serif;
      font-weight: 800;
      font-size: 2.2rem;
      color: var(--sky);
    }
    .stat-label {
      display: block;
      margin-top: 6px;
      font-size: 0.85rem;
      color: #C6CCDA;
      max-width: 200px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Features */
    .features { padding: 90px 0 30px; }
    .section-title {
      font-size: clamp(1.7rem, 3vw, 2.3rem);
      font-weight: 800;
      max-width: 640px;
      margin: 10px auto 0;
    }
    .section-title.center { text-align: center; margin-left: auto; margin-right: auto; }

    .feature-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: center;
      padding: 64px 0;
      border-bottom: 1px solid var(--line);
    }
    .feature-row:last-child { border-bottom: none; }
    .feature-row.reverse .feature-text { order: 2; }
    .feature-row.reverse .feature-image { order: 1; }

    .feature-tag {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--coral);
      margin-bottom: 12px;
    }
    .feature-text h3 {
      font-size: 1.65rem;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .feature-text > p { font-size: 1.02rem; margin-bottom: 20px; }
    .feature-list li {
      position: relative;
      padding-left: 26px;
      margin-bottom: 12px;
      font-size: 0.96rem;
      color: var(--slate);
    }
    .feature-list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--sky);
    }
    .feature-image img {
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    /* Callout */
    .callout {
      background: var(--navy);
      padding: 70px 0;
      margin: 40px 0;
    }
    .callout-inner { max-width: 780px; text-align: center; margin: 0 auto; }
    .callout h2 {
      color: #fff;
      font-size: clamp(1.5rem, 2.8vw, 2.1rem);
      font-weight: 700;
    }
    .callout p {
      color: #D6E0EF;
      margin-top: 18px;
      font-size: 1.05rem;
    }

    /* Journey */
    .journey { padding: 30px 0 90px; }
    .journey-grid {
      margin-top: 44px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
    .journey-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 28px 22px;
    }
    .journey-mark {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--sky);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .journey-card h4 { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; }
    .journey-card p { font-size: 0.92rem; }

    /* Pricing */
    .pricing { padding: 30px 0 90px; }
    .pricing-inner { display: flex; justify-content: center; }
    .pricing-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 48px 44px;
      max-width: 460px;
      width: 100%;
      box-shadow: var(--shadow);
      text-align: center;
    }
    .pricing-card h2 { font-size: 1.6rem; margin-top: 6px; }
    .price { margin-top: 20px; }
    .price-amount {
      font-family: 'Sora', sans-serif;
      font-weight: 800;
      font-size: 3.2rem;
      color: var(--navy);
    }
    .price-sub { margin-top: 6px; font-size: 0.88rem; }
    .pricing-list {
      text-align: left;
      margin-top: 30px;
      border-top: 1px solid var(--line);
      padding-top: 26px;
    }
    .pricing-list li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 14px;
      font-size: 0.95rem;
      color: var(--ink);
    }
    .pricing-list li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--sky);
      font-weight: 700;
    }

    /* Guarantee */
    .guarantee { padding: 0 0 90px; }
    .guarantee-inner {
      display: flex;
      align-items: center;
      gap: 26px;
      background: #EFF3F8;
      border-radius: var(--radius);
      padding: 34px 40px;
      max-width: 780px;
      margin: 0 auto;
    }
    .guarantee-icon { color: var(--navy); flex-shrink: 0; }
    .guarantee h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; }
    .guarantee p { font-size: 0.92rem; }

    /* Final CTA */
    .final-cta {
      background: var(--ink);
      padding: 90px 0;
    }
    .final-cta-inner { text-align: center; max-width: 640px; margin: 0 auto; }
    .final-cta h2 { color: #fff; font-size: clamp(1.7rem, 3vw, 2.4rem); }
    .final-cta p { color: #C6CCDA; margin-top: 18px; font-size: 1.05rem; }
    .final-cta .btn { margin-top: 32px; }

    /* Footer */
    .site-footer { padding: 44px 0; }
    .footer-inner { text-align: center; }
    .footer-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .footer-note {
      font-size: 0.82rem;
      max-width: 520px;
      margin: 0 auto 10px;
      color: #8792A6;
    }
    .footer-copy { font-size: 0.8rem; color: #A5ACBA; }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-visual { order: -1; margin-bottom: 10px; }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
      .feature-row { grid-template-columns: 1fr; gap: 30px; padding: 44px 0; }
      .feature-row.reverse .feature-text,
      .feature-row.reverse .feature-image { order: initial; }
      .journey-grid { grid-template-columns: repeat(2, 1fr); }
