---
const price = "7,99 €";
const gumroadUrl = "https://aghhol.gumroad.com/l/rokia-charia-ai";
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ruqya Charia IA — Diagnostic spirituel et bien-être par l'IA</title>
  <meta name="description" content="Ruqya Charia IA : premier assistant au monde reliant sciences islamiques authentiques et psychologie moderne. Analyse faciale IA, questionnaires cliniques, diagnostic spirituel précis et récitations coraniques de Ruqya personnalisées." />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="wrap header-inner">
      <a href="#top" class="brand">
        <img src="/images/logo.png" alt="Ruqya Charia IA" class="brand-mark" />
        <span class="brand-name">Ruqya Charia <em>IA</em></span>
      </a>
      <nav class="nav">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#diagnostic">Le diagnostic</a>
        <a href="#tarif">Tarif</a>
      </nav>
      <a href={gumroadUrl} class="btn btn-primary btn-small" target="_blank" rel="noopener">Essayer — {price}</a>
    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="hero">
      <div class="wrap hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Sciences islamiques × psychologie moderne</p>
          <h1>Comprenez ce que <span class="ink">votre âme</span> essaie de vous dire.</h1>
          <p class="hero-sub">
            Épuisement spirituel, mal-être émotionnel, anxiété sans cause apparente : plutôt que de deviner, Ruqya Charia IA analyse vos expressions faciales et croise les résultats avec des questionnaires psychologiques cliniques pour vous offrir un diagnostic spirituel précis — et des récitations coraniques de Ruqya adaptées à votre état.
          </p>
          <div class="hero-ctas">
            <a href={gumroadUrl} class="btn btn-primary" target="_blank" rel="noopener">Commencer mon diagnostic</a>
            <a href="#fonctionnalites" class="btn btn-ghost">Voir les fonctionnalités</a>
          </div>
          <p class="hero-microcopy">Disponible en français, anglais et arabe · Confidentialité totale</p>
        </div>
        <div class="hero-visual">
          <img src="/images/phone_home.png" alt="Écran d'accueil de Ruqya Charia IA" class="hero-phone" />
        </div>
      </div>
    </section>

    <!-- STATS BAND -->
    <section class="stats-band">
      <div class="wrap stats-inner">
        <div class="stat">
          <span class="stat-num">10 min</span>
          <span class="stat-label">pour un diagnostic psycho-spirituel complet</span>
        </div>
        <div class="stat">
          <span class="stat-num">3</span>
          <span class="stat-label">langues : français, anglais, arabe</span>
        </div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">analyse locale, confidentialité totale</span>
        </div>
        <div class="stat">
          <span class="stat-num">1ère</span>
          <span class="stat-label">application à fusionner IA faciale et sciences islamiques</span>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="fonctionnalites" class="features">
      <div class="wrap">
        <p class="eyebrow center">Fonctionnalités clés</p>
        <h2 class="section-title center">Un pont entre tradition authentique et technologie de précision</h2>
      </div>

      <!-- Feature 1: AI facial analysis -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Analyse faciale par IA</span>
          <h3>Une reconnaissance d'émotions de haute précision</h3>
          <p>Notre IA avancée (technologie MediaPipe/FER2013) analyse vos expressions faciales en temps réel, en toute sécurité et localement sur votre appareil — sans jamais transmettre vos données à des tiers.</p>
          <ul class="feature-list">
            <li>Reconnaissance faciale des émotions en temps réel</li>
            <li>Analyse 100% locale sur votre appareil</li>
            <li>Résultat en 1 à 2 minutes seulement</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_scanning.png" alt="Analyse faciale par IA dans Ruqya Charia IA" loading="lazy" />
        </div>
      </div>

      <!-- Feature 2: Holistic diagnostic -->
      <div class="feature-row wrap reverse" id="diagnostic">
        <div class="feature-text">
          <span class="feature-tag">Diagnostic psycho-spirituel</span>
          <h3>Trois étapes vers une réponse claire</h3>
          <p>Le diagnostic combine l'analyse des émotions faciales, un questionnaire psychologique validé (dépression, anxiété, stress) et une analyse IA qui relie vos résultats à un état spirituel reconnu — avec des recommandations personnalisées.</p>
          <ul class="feature-list">
            <li>1. Analyse des émotions faciales (1-2 min)</li>
            <li>2. Questionnaire psychologique validé (5-7 min)</li>
            <li>3. Analyse IA et résultats personnalisés (1 min)</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_assessment_overview.png" alt="Aperçu du diagnostic psycho-spirituel dans Ruqya Charia IA" loading="lazy" />
        </div>
      </div>

      <!-- Feature 3: Progress tracking -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Suivi de votre évolution</span>
          <h3>Votre parcours émotionnel et spirituel, dans le temps</h3>
          <p>Chaque diagnostic est enregistré et représenté sur un graphique d'évolution — dimension émotionnelle, spirituelle et psychologique — pour visualiser vos progrès session après session.</p>
          <ul class="feature-list">
            <li>Historique complet de vos évaluations</li>
            <li>Graphique de progression sur trois dimensions</li>
            <li>Score et recommandations à chaque étape</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_home.png" alt="Suivi de progression dans Ruqya Charia IA" loading="lazy" />
        </div>
      </div>

      <!-- Feature 4: Education -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Espace éducatif</span>
          <h3>Comprendre, avant de guérir</h3>
          <p>Des ressources claires sur la santé mentale en Islam, la dépression et l'anxiété d'un point de vue scientifique et spirituel, les pratiques spirituelles islamiques validées, et les signes qui doivent pousser à consulter un professionnel.</p>
          <ul class="feature-list">
            <li>La santé mentale expliquée sous l'angle islamique</li>
            <li>Pratiques spirituelles fondées sur des preuves</li>
            <li>Guide pour savoir quand consulter un professionnel</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_education.png" alt="Espace éducatif dans Ruqya Charia IA" loading="lazy" />
        </div>
      </div>

      <!-- Feature 5: Privacy -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Confidentialité absolue</span>
          <h3>Vos données les plus intimes restent les vôtres</h3>
          <p>Chiffrement de bout en bout, toutes les données stockées localement sur votre appareil, jamais partagées. Un espace sûr pour explorer ce que vous ressentez, en toute discrétion.</p>
          <ul class="feature-list">
            <li>Chiffrement de bout en bout</li>
            <li>Aucune donnée envoyée à des serveurs tiers</li>
            <li>Un espace privé, rien que pour vous</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_privacy_first.png" alt="Confidentialité dans Ruqya Charia IA" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- CALLOUT -->
    <section class="callout">
      <div class="wrap callout-inner">
        <h2>Une approche holistique, entre science et spiritualité</h2>
        <p>Ruqya Charia IA ne devine pas : elle croise science psychologique moderne et sagesse spirituelle islamique pour vous offrir une compréhension fondée de ce que vous traversez — et vous accompagner vers un véritable apaisement.</p>
      </div>
    </section>

    <!-- PRICING -->
    <section id="tarif" class="pricing">
      <div class="wrap pricing-inner">
        <div class="price-card">
          <p class="price-amount">Licence d'un mois</p>
          <p class="price">7,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 3 mois</p>
          <p class="price">19,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 6 mois</p>
          <p class="price">37,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 12 mois</p>
          <p class="price">59,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Durée de vie</p>
          <p class="price">129,99 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
      

    <!-- GUARANTEE -->
    <section class="guarantee">
      <div class="wrap guarantee-inner">
        <div class="guarantee-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" width="40" height="40">
            <path d="M24 4 L42 11 V22 C42 33 34.5 41.5 24 44 C13.5 41.5 6 33 6 22 V11 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M16 24 L21.5 29.5 L33 17" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h3>Livraison instantanée par Gumroad</h3>
          <p>Votre achat est traité de façon sécurisée sur Gumroad. Vous recevez votre accès immédiatement après le paiement, sans compte à créer sur un store tiers.</p>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="wrap final-cta-inner">
        <h2>Votre chemin vers l'apaisement<br/>commence par une meilleure compréhension.</h2>
        <p>Rejoignez Ruqya Charia IA et débutez votre parcours guidé vers le bien-être spirituel et mental.</p>
        <a href={gumroadUrl} class="btn btn-light" target="_blank" rel="noopener">Commencer maintenant — {price}</a>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <img src="/images/logo.png" alt="Ruqya Charia IA" class="brand-mark" />
        <span class="brand-name">Ruqya Charia <em>IA</em></span>
      </div>
      <p class="footer-note">Ruqya Charia IA propose un accompagnement psycho-spirituel et ne remplace pas un diagnostic médical, psychologique ou religieux établi par un professionnel qualifié. En cas de détresse importante, consultez un professionnel de santé.</p>
      <p class="footer-copy">© {new Date().getFullYear()} AGH Data Agency Holding SA. Tous droits réservés.</p>
    </div>
  </footer>

  <style>
    :root {
      --ink: #101B2E;
      --navy: #0F2A52;
      --blue: #3C8FD3;
      --gold: #E8B84B;
      --cream: #FAF9F6;
      --paper: #FFFFFF;
      --slate: #565A6B;
      --line: #E5E4EC;
      --radius: 18px;
      --shadow: 0 12px 32px -12px rgba(16, 27, 46, 0.22);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, sans-serif;
      color: var(--ink);
      background: var(--cream);
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4 {
      font-family: 'Lora', serif;
      margin: 0;
      line-height: 1.2;
      color: var(--ink);
    }
    p { margin: 0; color: var(--slate); line-height: 1.65; }
    a { text-decoration: none; color: inherit; }
    ul { margin: 0; padding: 0; list-style: none; }
    img { max-width: 100%; display: block; }
    em { font-style: italic; color: var(--gold); }

    .wrap {
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 28px;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 28px;
      border-radius: 999px;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 0.96rem;
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--gold);
      color: var(--navy);
      box-shadow: 0 8px 20px -8px rgba(232, 184, 75, 0.55);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 26px -8px rgba(232, 184, 75, 0.6); }
    .btn-small { padding: 10px 20px; font-size: 0.86rem; }
    .btn-ghost {
      border: 1.5px solid var(--line);
      color: var(--ink);
      background: transparent;
    }
    .btn-ghost:hover { border-color: var(--blue); background: rgba(60,143,211,0.06); }
    .btn-full { width: 100%; margin-top: 22px; }
    .btn-light {
      background: #fff;
      color: var(--navy);
      box-shadow: 0 8px 20px -8px rgba(0,0,0,0.3);
    }
    .btn-light:hover { transform: translateY(-2px); }

    /* Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(250, 249, 246, 0.88);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      padding-bottom: 14px;
    }
    .brand { display: flex; align-items: center; gap: 10px; }
    .brand-mark { width: 32px; height: 32px; object-fit: contain; }
    .brand-name { font-family: 'Lora', serif; font-weight: 600; font-size: 1.05rem; }
    .nav { display: flex; gap: 30px; }
    .nav a { font-size: 0.92rem; font-weight: 500; color: var(--slate); }
    .nav a:hover { color: var(--blue); }

    /* Hero */
    .hero { padding: 76px 0 40px; overflow: hidden; }
    .hero-inner {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 48px;
      align-items: center;
    }
    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 14px;
      display: block;
    }
    .eyebrow.center { text-align: center; }
    h1 { font-size: clamp(2.3rem, 4vw, 3.2rem); font-weight: 600; }
    h1 .ink { color: var(--blue); font-style: italic; }
    .hero-sub {
      margin-top: 22px;
      font-size: 1.08rem;
      max-width: 500px;
    }
    .hero-ctas { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
    .hero-microcopy {
      margin-top: 18px;
      font-size: 0.85rem;
      color: #8B8FA0;
    }

    .hero-visual { display: flex; justify-content: center; }
    .hero-phone {
      width: 100%;
      max-width: 290px;
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    /* Stats band */
    .stats-band {
      background: var(--navy);
      padding: 40px 0;
    }
    .stats-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .stat { text-align: center; color: #fff; }
    .stat-num {
      display: block;
      font-family: 'Lora', serif;
      font-weight: 700;
      font-size: 2.1rem;
      color: var(--gold);
    }
    .stat-label {
      display: block;
      margin-top: 6px;
      font-size: 0.85rem;
      color: #B7C0D4;
      max-width: 210px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Features */
    .features { padding: 90px 0 30px; }
    .section-title {
      font-size: clamp(1.7rem, 3vw, 2.2rem);
      font-weight: 600;
      max-width: 660px;
      margin: 10px auto 0;
    }
    .section-title.center { text-align: center; margin-left: auto; margin-right: auto; }

    .feature-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: center;
      padding: 64px 0;
      border-bottom: 1px solid var(--line);
    }
    .feature-row:last-child { border-bottom: none; }
    .feature-row.reverse .feature-text { order: 2; }
    .feature-row.reverse .feature-image { order: 1; }

    .feature-tag {
      display: inline-block;
      font-family: 'Inter', sans-serif;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 12px;
    }
    .feature-text h3 {
      font-size: 1.6rem;
      font-weight: 600;
      margin-bottom: 16px;
    }
    .feature-text > p { font-size: 1.02rem; margin-bottom: 20px; }
    .feature-list li {
      position: relative;
      padding-left: 26px;
      margin-bottom: 12px;
      font-size: 0.96rem;
      color: var(--slate);
    }
    .feature-list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--gold);
    }
    .feature-image { display: flex; justify-content: center; }
    .feature-image img {
      max-width: 260px;
    }

    /* Callout */
    .callout {
      background: var(--navy);
      padding: 70px 0;
      margin: 40px 0;
    }
    .callout-inner { max-width: 780px; text-align: center; margin: 0 auto; }
    .callout h2 {
      color: #fff;
      font-size: clamp(1.5rem, 2.8vw, 2.1rem);
      font-weight: 600;
    }
    .callout p {
      color: #C7D1E4;
      margin-top: 18px;
      font-size: 1.05rem;
      font-family: 'Inter', sans-serif;
    }

    /* Pricing */
    .pricing { padding: 30px 0 90px; }
    .pricing-inner { display: flex; justify-content: center; }
    .pricing-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 48px 44px;
      max-width: 460px;
      width: 100%;
      box-shadow: var(--shadow);
      text-align: center;
    }
    .pricing-card h2 { font-size: 1.55rem; margin-top: 6px; }
    .price { margin-top: 20px; }
    .price-amount {
      font-family: 'Lora', serif;
      font-weight: 700;
      font-size: 3.1rem;
      color: var(--navy);
    }
    .price-sub { margin-top: 6px; font-size: 0.88rem; }
    .pricing-list {
      text-align: left;
      margin-top: 30px;
      border-top: 1px solid var(--line);
      padding-top: 26px;
    }
    .pricing-list li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 14px;
      font-size: 0.95rem;
      color: var(--ink);
    }
    .pricing-list li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--blue);
      font-weight: 700;
    }

    /* Guarantee */
    .guarantee { padding: 0 0 90px; }
    .guarantee-inner {
      display: flex;
      align-items: center;
      gap: 26px;
      background: #EEF1F7;
      border-radius: var(--radius);
      padding: 34px 40px;
      max-width: 780px;
      margin: 0 auto;
    }
    .guarantee-icon { color: var(--navy); flex-shrink: 0; }
    .guarantee h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: 6px; }
    .guarantee p { font-size: 0.92rem; font-family: 'Inter', sans-serif; }

    /* Final CTA */
    .final-cta {
      background: var(--ink);
      padding: 90px 0;
    }
    .final-cta-inner { text-align: center; max-width: 640px; margin: 0 auto; }
    .final-cta h2 { color: #fff; font-size: clamp(1.7rem, 3vw, 2.3rem); font-weight: 600; }
    .final-cta p { color: #B7C0D4; margin-top: 18px; font-size: 1.05rem; font-family: 'Inter', sans-serif; }
    .final-cta .btn { margin-top: 32px; }

    /* Footer */
    .site-footer { padding: 44px 0; }
    .footer-inner { text-align: center; }
    .footer-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .footer-note {
      font-size: 0.82rem;
      max-width: 560px;
      margin: 0 auto 10px;
      color: #8B8FA0;
    }
    .footer-copy { font-size: 0.8rem; color: #9FA3B4; }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-visual { order: -1; margin-bottom: 10px; }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
      .feature-row { grid-template-columns: 1fr; gap: 30px; padding: 44px 0; }
      .feature-row.reverse .feature-text,
      .feature-row.reverse .feature-image { order: initial; }
      .nav { display: none; }
      .guarantee-inner { flex-direction: column; text-align: center; }
    }
    @media (max-width: 560px) {
      .stats-inner { grid-template-columns: 1fr 1fr; }
      .pricing-card { padding: 36px 26px; }
    }
  </style>
</body>
</html>
