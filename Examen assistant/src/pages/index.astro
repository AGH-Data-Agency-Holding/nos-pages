---
const gumroadUrl = "https://aghhol.gumroad.com/l/zclcjl";
---
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam Assistant — Le tuteur IA hors-ligne pour réussir tes examens</title>
  <meta name="description" content="QCM générés par IA, tuteur 100% hors-ligne, suivi de progression intelligent. Révise sans Wi-Fi, même en mode avion." />
  <link rel="icon" href="/images/icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #F6F6FD;
      --lavender: #EEEEFC;
      --indigo: #5B4FE0;
      --indigo-dark: #3F35B0;
      --navy: #1B1B3A;
      --orange: #F5821F;
      --ink: #1E1E2E;
      --line: #E1E0F6;
      font-family: Inter, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--bg); color: var(--ink); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 600; letter-spacing: -0.01em; color: var(--navy); margin: 0; }
    .eyebrow { font-family: "JetBrains Mono", monospace; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--indigo-dark); font-weight: 700; }
    a { color: inherit; }
    .btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; font-size: .95rem; padding: 14px 26px; border-radius: 100px; text-decoration: none; transition: transform .15s ease, box-shadow .15s ease; }
    .btn-primary { background: var(--indigo); color: #F7F7FF; box-shadow: 0 8px 22px rgba(91,79,224,.35); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(91,79,224,.42); }
    .btn-ghost { border: 1.5px solid var(--navy); color: var(--navy); }
    .btn-ghost:hover { background: var(--navy); color: #fff; }

    header { position: sticky; top: 0; z-index: 40; background: rgba(246,246,253,.88); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
    .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; }
    .brand { display: flex; align-items: center; gap: 10px; font-family: "Fraunces", serif; font-weight: 700; font-size: 1.15rem; color: var(--navy); text-decoration: none; }
    .brand img { width: 32px; height: 32px; border-radius: 9px; }
    .nav-links { display: flex; gap: 28px; font-size: .92rem; font-weight: 500; }
    .nav-links a { text-decoration: none; color: var(--navy); }
    .nav-links a:hover { color: var(--indigo); }
    @media (max-width: 780px) { .nav-links { display: none; } }

    .hero { padding: 70px 0 30px; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 44px; align-items: center; }
    @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero h1 { font-size: clamp(2.2rem, 4.2vw, 3.2rem); line-height: 1.08; margin: 14px 0 18px; }
    .hero h1 em { font-style: italic; color: var(--indigo); }
    .hero p.lede { font-size: 1.08rem; line-height: 1.6; color: #4A4A63; max-width: 470px; margin-bottom: 28px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
    .trust-line { font-size: .85rem; color: #4A4A63; font-family: "JetBrains Mono", monospace; }
    .trust-line strong { color: var(--orange); }
    .hero-visual { display: flex; justify-content: center; position: relative; }
    .glow { position: absolute; width: 380px; height: 380px; border-radius: 50%; background: radial-gradient(circle, rgba(91,79,224,.18), transparent 65%); top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .phone-frame { position: relative; width: 250px; border-radius: 32px; overflow: hidden; box-shadow: 0 30px 60px rgba(27,27,58,.22); border: 6px solid var(--navy); }

    .band-navy { background: var(--navy); color: #EDEDFB; padding: 46px 0; }
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
    @media (max-width: 780px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-grid .num { font-family: "Fraunces", serif; font-size: 2rem; color: var(--orange); }
    .stat-grid .label { font-size: .76rem; color: #B7B6E0; font-family: "JetBrains Mono", monospace; letter-spacing: .04em; margin-top: 4px; }

    .feature-section { padding: 100px 0; }
    .feature-row { display: grid; grid-template-columns: .9fr 1.1fr; gap: 54px; align-items: center; margin-bottom: 100px; }
    .feature-row.reverse { grid-template-columns: 1.1fr .9fr; }
    .feature-row.reverse .feature-copy { order: 2; }
    .feature-row.reverse .feature-shot { order: 1; }
    @media (max-width: 860px) {
      .feature-row, .feature-row.reverse { grid-template-columns: 1fr; }
      .feature-row.reverse .feature-copy, .feature-row.reverse .feature-shot { order: unset; }
    }
    .feature-shot { display: flex; justify-content: center; }
    .feature-shot img { width: 100%; max-width: 270px; border-radius: 24px; box-shadow: 0 24px 48px rgba(27,27,58,.16); border: 5px solid #fff; }
    .feature-copy h3 { font-size: 1.6rem; margin: 12px 0 14px; }
    .feature-copy p { color: #4A4A63; line-height: 1.65; font-size: 1rem; max-width: 420px; }
    .feature-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .feature-tags span { font-family: "JetBrains Mono", monospace; font-size: .7rem; letter-spacing: .03em; background: var(--lavender); color: var(--indigo-dark); padding: 6px 12px; border-radius: 100px; }

    .band-indigo { background: linear-gradient(120deg, var(--indigo) 0%, var(--indigo-dark) 100%); color: #F3F2FF; padding: 60px 0; text-align: center; }
    .band-indigo .eyebrow { color: #D9D6FF; }
    .band-indigo h2 { color: #F3F2FF; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 12px auto 14px; max-width: 640px; }
    .band-indigo p { max-width: 540px; margin: 0 auto; color: #D9D6FF; line-height: 1.6; }

    .price-section { padding: 90px 0; text-align: center; }
    .price-card { max-width: 380px; margin: 40px auto 0; background: #fff; border: 1px solid var(--line); border-radius: 22px; padding: 34px; }
    .price-card .price { font-family: "Fraunces", serif; font-size: 2.6rem; margin: 10px 0 4px; }
    .price-card .price span { font-size: 1rem; font-family: Inter, sans-serif; font-weight: 500; color: #4A4A63; }
    .price-card ul { list-style: none; padding: 0; margin: 22px 0 26px; text-align: left; }
    .price-card li { padding: 8px 0; font-size: .94rem; border-top: 1px solid var(--line); }
    .price-card li:first-child { border-top: none; }

    .guarantee { padding: 0 0 100px; }
    .guarantee-box { background: var(--lavender); border-radius: 24px; padding: 46px; text-align: center; }
    .guarantee-box h2 { font-size: 1.5rem; margin: 10px 0 12px; }
    .guarantee-box p { max-width: 560px; margin: 0 auto; color: var(--ink); line-height: 1.6; }

    .final-cta { background: var(--navy); color: #EDEDFB; padding: 90px 0; text-align: center; }
    .final-cta h2 { color: #F7F7FF; font-size: clamp(1.8rem, 3.2vw, 2.5rem); margin: 10px 0 16px; }
    .final-cta p { color: #B7B6E0; max-width: 480px; margin: 0 auto 30px; }
    .lang-row { margin-top: 32px; font-family: "JetBrains Mono", monospace; font-size: .78rem; color: #7A79AE; letter-spacing: .05em; }

    footer { padding: 34px 0; text-align: center; font-size: .85rem; color: #4A4A63; }
  </style>
</head>
<body>

  <header>
    <div class="wrap nav">
      <a class="brand" href="#top">
        <img src="/images/icon.png" alt="Logo Exam Assistant" />
        Exam Assistant
      </a>
      <nav class="nav-links">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#tarif">Tarif</a>
        <a href="#garantie">Garantie</a>
      </nav>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger</a>
    </div>
  </header>

  <section class="hero" id="top">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">Tuteur IA · 100% hors-ligne</span>
        <h1>Révise plus <em>intelligemment</em>, pas plus longtemps.</h1>
        <p class="lede">Un tuteur IA dans ta poche, disponible 24/7 même en mode avion. Des QCM générés instantanément, des résumés clairs, et un suivi qui repère tes points faibles avant l'examen.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger l'app</a>
          <a class="btn btn-ghost" href="#fonctionnalites">Voir les fonctionnalités</a>
        </div>
        <p class="trust-line">Garantie de remboursement de 6 mois · <strong>zéro Wi-Fi requis</strong></p>
      </div>
      <div class="hero-visual">
        <div class="glow"></div>
        <div class="phone-frame">
          <img src="/images/screen-home.png" alt="Tableau de bord Exam Assistant" />
        </div>
      </div>
    </div>
  </section>

  <section class="band-navy">
    <div class="wrap stat-grid">
      <div>
        <div class="num">10x</div>
        <div class="label">MÉMORISATION PLUS RAPIDE</div>
      </div>
      <div>
        <div class="num">100%</div>
        <div class="label">FONCTIONNE HORS-LIGNE</div>
      </div>
      <div>
        <div class="num">24/7</div>
        <div class="label">TUTEUR IA DISPONIBLE</div>
      </div>
      <div>
        <div class="num">0</div>
        <div class="label">DISTRACTION, ZÉRO NOTIFICATION</div>
      </div>
    </div>
  </section>

  <section class="feature-section" id="fonctionnalites">
    <div class="wrap">

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-quiz.png" alt="QCM généré pour réviser une leçon" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">QCM & quiz intelligents</span>
          <h3>Teste tes connaissances instantanément.</h3>
          <p>L'app génère des questions à choix multiples sur n'importe quel sujet pour mémoriser 10 fois plus vite qu'en relisant simplement tes notes.</p>
          <div class="feature-tags"><span>QCM INSTANTANÉS</span><span>CORRECTION IMMÉDIATE</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-ai-chat.png" alt="Tuteur IA hors-ligne qui répond aux questions" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Tuteur IA 100% hors-ligne</span>
          <h3>Pose tes questions, même sans une barre de réseau.</h3>
          <p>Demande une explication, un résumé ou un exemple — le tuteur répond directement depuis ton téléphone, aucune connexion nécessaire.</p>
          <div class="feature-tags"><span>ZÉRO WI-FI</span><span>RÉPONSES INSTANTANÉES</span></div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-shot">
          <img src="/images/screen-analytics.png" alt="Suivi de progression et statistiques de révision" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Suivi de progression intelligent</span>
          <h3>Repère tes points faibles avant qu'ils ne coûtent des points.</h3>
          <p>Temps de révision, taux de réussite par matière, progression hebdomadaire — tout est visible pour concentrer ton effort là où il compte.</p>
          <div class="feature-tags"><span>STATISTIQUES</span><span>PAR MATIÈRE</span></div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-shot">
          <img src="/images/screen-missions.png" alt="Missions quotidiennes et objectifs de révision" />
        </div>
        <div class="feature-copy">
          <span class="eyebrow">Missions & régularité</span>
          <h3>Un objectif clair chaque jour, pour ne jamais décrocher.</h3>
          <p>Des petites missions quotidiennes (flashcards, lecture, quiz) et une série de jours actifs pour garder la motivation jusqu'au jour J.</p>
          <div class="feature-tags"><span>OBJECTIFS QUOTIDIENS</span><span>SÉRIE ACTIVE</span></div>
        </div>
      </div>

    </div>
  </section>

  <section class="band-indigo">
    <div class="wrap">
      <span class="eyebrow">Conçu pour réviser vraiment</span>
      <h2>Zéro Wi-Fi, zéro distraction — juste toi et tes révisions.</h2>
      <p>Le tuteur, les QCM et le suivi de progression fonctionnent entièrement hors-ligne, y compris en mode avion.</p>
    </div>
  </section>

  <section class="price-section" id="tarif">
    <span class="eyebrow">Tarif</span>
    <h2 style="margin-top:10px;">Un prix simple, pas d'abonnement caché.</h2>
    <div class="price-card" style="max-width: 760px; margin: 40px auto 0; background: #fff; border: 1px solid var(--line); border-radius: 22px; padding: 18px; text-align: left;">
      <div class="plan-row" style="display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 16px 8px; border-top: none; flex-wrap: wrap;">
        <div class="price" style="font-family: 'Fraunces', serif; font-size: 1.4rem; margin: 0; color: var(--ink); min-width: 120px;">26,22 €</div>
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 18px; flex: 1; flex-wrap: wrap;">
          <div style="font-weight: 600; color: var(--ink);">Licence d'un mois</div>
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="padding: 10px 16px; font-size: 0.9rem;">Télécharger maintenant</a>
        </div>
      </div>
      <div class="plan-row" style="display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 16px 8px; border-top: 1px solid var(--line); flex-wrap: wrap;">
        <div class="price" style="font-family: 'Fraunces', serif; font-size: 1.4rem; margin: 0; color: var(--ink); min-width: 120px;">52,45 €</div>
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 18px; flex: 1; flex-wrap: wrap;">
          <div style="font-weight: 600; color: var(--ink);">Licence de 3 mois</div>
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="padding: 10px 16px; font-size: 0.9rem;">Télécharger maintenant</a>
        </div>
      </div>
      <div class="plan-row" style="display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 16px 8px; border-top: 1px solid var(--line); flex-wrap: wrap;">
        <div class="price" style="font-family: 'Fraunces', serif; font-size: 1.4rem; margin: 0; color: var(--ink); min-width: 120px;">104,91 €</div>
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 18px; flex: 1; flex-wrap: wrap;">
          <div style="font-weight: 600; color: var(--ink);">Licence de 6 mois</div>
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="padding: 10px 16px; font-size: 0.9rem;">Télécharger maintenant</a>
        </div>
      </div>
      <div class="plan-row" style="display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 16px 8px; border-top: 1px solid var(--line); flex-wrap: wrap;">
        <div class="price" style="font-family: 'Fraunces', serif; font-size: 1.4rem; margin: 0; color: var(--ink); min-width: 120px;">174,86 €</div>
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 18px; flex: 1; flex-wrap: wrap;">
          <div style="font-weight: 600; color: var(--ink);">Licence de 12 mois</div>
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="padding: 10px 16px; font-size: 0.9rem;">Télécharger maintenant</a>
        </div>
      </div>
      <div class="plan-row" style="display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 16px 8px; border-top: 1px solid var(--line); flex-wrap: wrap;">
        <div class="price" style="font-family: 'Fraunces', serif; font-size: 1.4rem; margin: 0; color: var(--ink); min-width: 120px;">349,73 €</div>
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 18px; flex: 1; flex-wrap: wrap;">
          <div style="font-weight: 600; color: var(--ink);">Durée de vie (accès à vie)</div>
          <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener" style="padding: 10px 16px; font-size: 0.9rem;">Télécharger maintenant</a>
        </div>
      </div>
    </div>
  </section>

  <section class="guarantee" id="garantie">
    <div class="wrap">
      <div class="guarantee-box">
        <span class="eyebrow">Garantie</span>
        <h2>Garantie de remboursement de 6 mois.</h2>
        <p>Si l'application ne t'aide pas à mieux réviser, tu es intégralement remboursé, sans justification à donner.</p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="wrap">
      <span class="eyebrow" style="color:#8D8AC7">Prêt à réviser autrement ?</span>
      <h2>Ton prochain examen mérite mieux qu'un onglet Wikipédia.</h2>
      <p>Télécharge Exam Assistant et génère ton premier quiz dès ce soir.</p>
      <a class="btn btn-primary" href={gumroadUrl} target="_blank" rel="noopener">Télécharger Exam Assistant</a>
      <div class="lang-row">DISPONIBLE EN FRANÇAIS · ENGLISH · العربية</div>
    </div>
  </section>

  <footer>
    <div class="wrap">© 2026 AGH Data Agency Holding — Exam Assistant. Tous droits réservés.</div>
  </footer>

</body>
</html>
