							<a href="https://aghhol.gumroad.com/l/makeup-skincare-ai" class="btn btn-primary btn-full" style="margin-top:0; width:auto; padding: 10px 16px; font-size: 0.85rem;">Télécharger maintenant</a>
						</li>
						<li style="display:flex; align-items:center; justify-content:space-between; gap:14px;">
							<span style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--ink);">39,99 €</span>
							<span style="flex:1; text-align:right;">Licence de 6 mois</span>
							<a href="https://aghhol.gumroad.com/l/makeup-skincare-ai" class="btn btn-primary btn-full" style="margin-top:0; width:auto; padding: 10px 16px; font-size: 0.85rem;">Télécharger maintenant</a>
						</li>
