// Esthetique AI — landing page
// Copy source: https://aghhol.gumroad.com/l/makeup-skincare-ai (French version of the Gumroad listing)
---

<html lang="fr">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Esthetique AI — Routine Visage &amp; Diagnostic Peau par IA</title>
	<meta name="description" content="Esthetique AI révolutionne les soins du visage grâce à une IA analytique de pointe. Diagnostic dermatologique en 30 secondes, avatar 3D évolutif, routine gamifiée." />
	<link rel="icon" href="/images/logo-mark.png" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

	<!-- ===== HEADER ===== -->
	<header class="site-header">
		<div class="wrap header-inner">
			<a href="#top" class="brand">
				<img src="/images/logo-mark.png" alt="Esthetique AI" class="brand-mark" />
				<span class="brand-name">Esthetique AI</span>
			</a>
			<nav class="nav">
				<a href="#diagnostic">Diagnostic</a>
				<a href="#gamification">Gamification</a>
				<a href="#marketplace">Marketplace</a>
				<a href="#prix">Tarif</a>
			</nav>
			<a href="https://aghhol.gumroad.com/l/makeup-skincare-ai" class="btn btn-header">Essayer maintenant</a>
		</div>
	</header>

	<main id="top">

		<!-- ===== HERO ===== -->
		<section class="hero">
			<div class="wrap hero-inner">
				<div class="hero-copy">
					<p class="eyebrow">Écosystème beauté gamifié — propulsé par l'IA</p>
					<h1>Votre peau, <em>lue</em> en 30 secondes.</h1>
					<p class="hero-sub">
						Esthetique AI révolutionne les soins du visage grâce à une intelligence artificielle analytique de pointe.
						Obtenez un diagnostic dermatologique précis à partir d'un simple selfie pour analyser l'acné, l'hydratation
						et les pores — puis découvrez une routine sur mesure adaptée à votre type de peau et à votre budget.
					</p>
					<div class="hero-cta-row">
						<a href="https://aghhol.gumroad.com/l/makeup-skincare-ai" class="btn btn-primary">Commencer le diagnostic — 2&nbsp;$</a>
						<span class="hero-cta-note">Garantie de remboursement de 6 mois</span>
					</div>
				</div>
				<div class="hero-visual">
					<div class="scan-frame">
						<img src="/images/home.png" alt="Écran d'accueil de l'application Esthetique AI" class="phone-mock" />
						<span class="corner corner-tl"></span>
						<span class="corner corner-tr"></span>
						<span class="corner corner-bl"></span>
						<span class="corner corner-br"></span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== STATS BAND ===== -->
		<section class="stats-band">
			<div class="wrap stats-grid">
				<div class="stat">
					<span class="stat-num">98%</span>
					<span class="stat-label">précision du diagnostic IA</span>
				</div>
				<div class="stat">
					<span class="stat-num">10M</span>
					<span class="stat-label">selfies multiraciaux analysés pour entraîner le modèle</span>
				</div>
				<div class="stat">
					<span class="stat-num">30 s</span>
					<span class="stat-label">pour obtenir votre analyse complète</span>
				</div>
				<div class="stat">
					<span class="stat-num">5&nbsp;000+</span>
					<span class="stat-label">marques Clean Beauty référencées</span>
				</div>
			</div>
		</section>

		<!-- ===== FEATURE 1 — DIAGNOSTIC ===== -->
		<section class="feature" id="diagnostic">
			<div class="wrap feature-inner">
				<div class="feature-copy">
					<span class="feature-index">Diagnostic</span>
					<h2>Un diagnostic de peau avec une précision de 98&nbsp;%</h2>
					<p>
						Positionnez votre visage dans le cadre, et l'IA analyse instantanément l'hydratation, le niveau d'huile,
						l'acné, les pores et la texture — avec une précision médicale entraînée sur 10 millions de données
						multiraciales. Le résultat s'affiche en quelques secondes, avec des repères visuels clairs sur votre écran.
					</p>
					<ul class="feature-list">
						<li>Cadrage guidé et conseils de luminosité avant chaque scan</li>
						<li>Rapport détaillé : hydratation, niveau d'huile, sévérité de l'acné</li>
						<li>Historique de vos scans pour suivre l'évolution dans le temps</li>
					</ul>
				</div>
				<div class="feature-visual">
					<div class="scan-frame scan-frame-alt">
						<img src="/images/skinscan.png" alt="Écran de scan IA de la peau" class="phone-mock" />
						<span class="corner corner-tl"></span>
						<span class="corner corner-tr"></span>
						<span class="corner corner-bl"></span>
						<span class="corner corner-br"></span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FEATURE 2 — AVATAR 3D ===== -->
