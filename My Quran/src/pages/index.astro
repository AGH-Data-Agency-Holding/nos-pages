---
const gumroadUrl = "https://aghhol.gumroad.com/l/coran-ai-hifz";
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Quran — Apprenez le Tajwid avec l'IA, 100% hors-ligne</title>
  <meta name="description" content="My Quran : votre professeur de Tajwid par IA, 100% hors-ligne et privé. Correction en temps réel de votre récitation, Coran complet avec audio, mode nuit. Gratuit, sans abonnement." />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="wrap header-inner">
      <a href="#top" class="brand">
        <img src="/images/logo.png" alt="My Quran" class="brand-mark" />
        <span class="brand-name">My <em>Quran</em></span>
      </a>
      <nav class="nav">
        <a href="#fonctionnalites">Fonctionnalités</a>
        <a href="#communaute">Communauté</a>
        <a href="#tarif">Gratuit</a>
      </nav>
      <a href={gumroadUrl} class="btn btn-primary btn-small" target="_blank" rel="noopener">Télécharger — Gratuit</a>
    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="hero">
      <div class="wrap hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Professeur de Tajwid par IA · 100% hors-ligne</p>
          <h1>Récitez avec <span class="ink">précision</span>, en toute intimité.</h1>
          <p class="hero-sub">
            Vous n'avez pas de professeur ou de connexion Wi-Fi ? My Quran écoute votre récitation et vous corrige en temps réel, entièrement hors-ligne et en toute confidentialité — pour progresser à votre rythme, sans jugement.
          </p>
          <div class="hero-ctas">
            <a href={gumroadUrl} class="btn btn-primary" target="_blank" rel="noopener">Commencer ma récitation</a>
            <a href="#fonctionnalites" class="btn btn-ghost">Voir les fonctionnalités</a>
          </div>
          <p class="hero-microcopy">100% gratuit · Aucun abonnement · Aucun suivi de données</p>
        </div>
        <div class="hero-visual">
          <img src="/images/phone_lecture_start.png" alt="Assistant IA Coran de My Quran" class="hero-phone" />
        </div>
      </div>
    </section>

    <!-- STATS BAND -->
    <section class="stats-band">
      <div class="wrap stats-inner">
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">fonctionne hors-ligne, en toute confidentialité</span>
        </div>
        <div class="stat">
          <span class="stat-num">0</span>
          <span class="stat-label">abonnement, suivi de données ou publicité</span>
        </div>
        <div class="stat">
          <span class="stat-num">114</span>
          <span class="stat-label">sourates, Coran complet avec audio</span>
        </div>
        <div class="stat">
          <span class="stat-num">Gratuit</span>
          <span class="stat-label">dès aujourd'hui, sans carte bancaire</span>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="fonctionnalites" class="features">
      <div class="wrap">
        <p class="eyebrow center">Fonctionnalités clés</p>
        <h2 class="section-title center">Un espace calme et exigeant pour progresser</h2>
      </div>

      <!-- Feature 1: AI correction -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Correction IA en temps réel</span>
          <h3>L'IA analyse chaque mot que vous récitez</h3>
          <p>Écoutez le verset, appuyez sur le micro et récitez. Notre IA analyse les règles de Tajweed et votre prononciation en temps réel, verset par verset, pour vous aider à perfectionner votre récitation.</p>
          <ul class="feature-list">
            <li>Analyse de la prononciation et des Makharij</li>
            <li>Détection des règles de Tajweed non respectées</li>
            <li>Fonctionne entièrement hors-ligne</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_lecture_recording.png" alt="Enregistrement de récitation dans My Quran" loading="lazy" />
        </div>
      </div>

      <!-- Feature 2: Detailed corrections -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Corrections détaillées</span>
          <h3>Un score précis, mot par mot</h3>
          <p>Après chaque récitation, obtenez un score de précision et des corrections détaillées pour chaque mot : quelle règle de Tajweed appliquer, comment prononcer correctement chaque lettre — puis réessayez jusqu'à la perfection.</p>
          <ul class="feature-list">
            <li>Score de précision instantané</li>
            <li>Explication de chaque erreur, règle par règle</li>
            <li>Réessai illimité, à votre rythme</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_lecture_correction.png" alt="Corrections détaillées de récitation dans My Quran" loading="lazy" />
        </div>
      </div>

      <!-- Feature 3: History -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Historique & suivi</span>
          <h3>Toute votre progression, en un coup d'œil</h3>
          <p>Retrouvez l'historique complet de vos récitations, duas et quiz, avec votre score pour chacun. Une vue claire de votre régularité, jour après jour.</p>
          <ul class="feature-list">
            <li>Historique des récitations, duas et quiz</li>
            <li>Scores et progression sauvegardés</li>
            <li>Recherche et filtres rapides</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_history.png" alt="Historique de récitation dans My Quran" loading="lazy" />
        </div>
      </div>

      <!-- Feature 4: Quiz & stats -->
      <div class="feature-row wrap reverse">
        <div class="feature-text">
          <span class="feature-tag">Quiz & statistiques</span>
          <h3>Testez vos connaissances, suivez vos progrès</h3>
          <p>Des quiz réguliers sur les sourates étudiées, avec un tableau de statistiques détaillé : score moyen, activité des 7 derniers jours, et historique de chaque quiz passé.</p>
          <ul class="feature-list">
            <li>Quiz par sourate avec score détaillé</li>
            <li>Statistiques d'activité sur 7 jours</li>
            <li>Niveau et progression globale</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_quiz_stats.png" alt="Statistiques de quiz dans My Quran" loading="lazy" />
        </div>
      </div>

      <!-- Feature 5: Gamification -->
      <div class="feature-row wrap">
        <div class="feature-text">
          <span class="feature-tag">Progression & motivation</span>
          <h3>Un compagnon qui vous garde motivé</h3>
          <p>Niveaux, badges, séries de jours consécutifs et versets lus : chaque effort est valorisé. Rejoignez le classement quotidien, hebdomadaire ou mensuel pour vous mesurer à la communauté.</p>
          <ul class="feature-list">
            <li>Niveaux, badges et pièces à collectionner</li>
            <li>Suivi des séries de jours consécutifs</li>
            <li>Classement quotidien, hebdomadaire et mensuel</li>
          </ul>
        </div>
        <div class="feature-image">
          <img src="/images/phone_profile.png" alt="Profil et progression dans My Quran" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- CALLOUT / COMMUNITY -->
    <section id="communaute" class="callout">
      <div class="wrap callout-inner">
        <div class="callout-image">
          <img src="/images/phone_challenges.png" alt="Défis religieux communautaires dans My Quran" loading="lazy" />
        </div>
        <div class="callout-text">
          <h2>Progressez ensemble, à travers des défis quotidiens</h2>
          <p>Rejoignez des défis religieux partagés par la communauté — mémorisation, Tajweed, réflexion — likez, commentez et partagez vos avancées avec d'autres personnes engagées dans le même chemin.</p>
          <div class="callout-list">
            <span>Défis communautaires quotidiens</span>
            <span>Calendrier d'événements (prières, quiz, adhkar)</span>
            <span>Rappels personnalisés par notification</span>
          </div>
        </div>
      </div>
    </section>

    <!-- LEADERBOARD MINI SHOWCASE -->
    <section class="showcase">
      <div class="wrap showcase-inner">
        <div class="showcase-text">
          <p class="eyebrow">Classement & communauté</p>
          <h2>Mesurez vos progrès face à la communauté</h2>
          <p>Le tableau des meilleurs récitants se met à jour chaque jour. Grimpez le classement à force de régularité, sans jamais perdre de vue votre propre objectif spirituel.</p>
        </div>
        <div class="showcase-image">
          <img src="/images/phone_leaderboard.png" alt="Classement des utilisateurs dans My Quran" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- PRICING / FREE -->
    <section id="tarif" class="pricing">
      <div class="wrap pricing-inner">
        <div class="price-card">
          <p class="price-amount">Licence d'un mois</p>
          <p class="price">26,22 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 3 mois</p>
          <p class="price">52,45 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 6 mois</p>
          <p class="price">104,91 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Licence de 12 mois</p>
          <p class="price">174,86 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
        <div class="price-card">
          <p class="price-amount">Durée de vie</p>
          <p class="price">349,73 €</p>
          <a href={{gumroadUrl}} class="btn btn-primary btn-full" target="_blank" rel="noopener">Télécharger maintenant</a>
        </div>
      

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="wrap final-cta-inner">
        <h2>Prenez le temps de progresser<br/>dans votre récitation, dès aujourd'hui.</h2>
        <p>📖 Un espace calme et exigeant, rien que pour vous et le Coran. 🤲</p>
        <a href={gumroadUrl} class="btn btn-light" target="_blank" rel="noopener">Télécharger My Quran — Gratuit</a>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <img src="/images/logo.png" alt="My Quran" class="brand-mark" />
        <span class="brand-name">My <em>Quran</em></span>
      </div>
      <p class="footer-note">My Quran est un outil d'accompagnement à la récitation et ne remplace pas l'enseignement d'un professeur ou d'un savant qualifié.</p>
      <p class="footer-copy">© {new Date().getFullYear()} AGH Data Agency Holding SA. Tous droits réservés.</p>
    </div>
  </footer>

  <style>
    :root {
      --ink: #12291A;
      --green: #0E4A1E;
      --green-bright: #1B8A34;
      --gold: #E8B84B;
      --cream: #F7F8F5;
      --paper: #FFFFFF;
      --slate: #52604F;
      --line: #E1E7DE;
      --radius: 18px;
      --shadow: 0 12px 32px -12px rgba(14, 74, 30, 0.22);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, sans-serif;
      color: var(--ink);
      background: var(--cream);
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4 {
      font-family: 'Outfit', sans-serif;
      margin: 0;
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--ink);
    }
    p { margin: 0; color: var(--slate); line-height: 1.65; }
    a { text-decoration: none; color: inherit; }
    ul { margin: 0; padding: 0; list-style: none; }
    img { max-width: 100%; display: block; }
    em { font-style: normal; color: var(--gold); }

    .wrap {
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 28px;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 28px;
      border-radius: 999px;
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 0.96rem;
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--green-bright);
      color: #fff;
      box-shadow: 0 8px 20px -8px rgba(27, 138, 52, 0.5);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 26px -8px rgba(27, 138, 52, 0.55); }
    .btn-small { padding: 10px 20px; font-size: 0.86rem; }
    .btn-ghost {
      border: 1.5px solid var(--line);
      color: var(--ink);
      background: transparent;
    }
    .btn-ghost:hover { border-color: var(--green-bright); background: rgba(27,138,52,0.05); }
    .btn-full { width: 100%; margin-top: 22px; }
    .btn-light {
      background: var(--gold);
      color: var(--ink);
      box-shadow: 0 8px 20px -8px rgba(0,0,0,0.35);
    }
    .btn-light:hover { transform: translateY(-2px); }

    /* Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(247, 248, 245, 0.88);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      padding-bottom: 14px;
    }
    .brand { display: flex; align-items: center; gap: 10px; }
    .brand-mark { width: 32px; height: 32px; object-fit: contain; border-radius: 8px; }
    .brand-name { font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.05rem; }
    .nav { display: flex; gap: 30px; }
    .nav a { font-size: 0.92rem; font-weight: 500; color: var(--slate); }
    .nav a:hover { color: var(--green-bright); }

    /* Hero */
    .hero { padding: 76px 0 40px; overflow: hidden; }
    .hero-inner {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 48px;
      align-items: center;
    }
    .eyebrow {
      font-family: 'Outfit', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--green-bright);
      margin-bottom: 14px;
      display: block;
    }
    .eyebrow.center { text-align: center; }
    h1 { font-size: clamp(2.4rem, 4.2vw, 3.4rem); font-weight: 700; }
    h1 .ink { color: var(--green-bright); }
    .hero-sub {
      margin-top: 22px;
      font-size: 1.1rem;
      max-width: 480px;
    }
    .hero-ctas { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
    .hero-microcopy {
      margin-top: 18px;
      font-size: 0.85rem;
      color: #8A9587;
    }

    .hero-visual { display: flex; justify-content: center; }
    .hero-phone {
      width: 100%;
      max-width: 300px;
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    /* Stats band */
    .stats-band {
      background: var(--ink);
      padding: 40px 0;
    }
    .stats-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .stat { text-align: center; color: #fff; }
    .stat-num {
      display: block;
      font-family: 'Outfit', sans-serif;
      font-weight: 800;
      font-size: 2.1rem;
      color: var(--gold);
    }
    .stat-label {
      display: block;
      margin-top: 6px;
      font-size: 0.85rem;
      color: #B8C4B5;
      max-width: 200px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Features */
    .features { padding: 90px 0 30px; }
    .section-title {
      font-size: clamp(1.7rem, 3vw, 2.3rem);
      font-weight: 700;
      max-width: 640px;
      margin: 10px auto 0;
    }
    .section-title.center { text-align: center; margin-left: auto; margin-right: auto; }

    .feature-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: center;
      padding: 64px 0;
      border-bottom: 1px solid var(--line);
    }
    .feature-row:last-child { border-bottom: none; }
    .feature-row.reverse .feature-text { order: 2; }
    .feature-row.reverse .feature-image { order: 1; }

    .feature-tag {
      display: inline-block;
      font-family: 'Outfit', sans-serif;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--green-bright);
      margin-bottom: 12px;
    }
    .feature-text h3 {
      font-size: 1.65rem;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .feature-text > p { font-size: 1.02rem; margin-bottom: 20px; }
    .feature-list li {
      position: relative;
      padding-left: 26px;
      margin-bottom: 12px;
      font-size: 0.96rem;
      color: var(--slate);
    }
    .feature-list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--gold);
    }
    .feature-image { display: flex; justify-content: center; }
    .feature-image img {
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      max-width: 280px;
    }

    /* Callout / community */
    .callout {
      background: var(--paper);
      padding: 80px 0;
      margin: 40px 0;
    }
    .callout-inner {
      display: grid;
      grid-template-columns: 0.7fr 1.3fr;
      gap: 56px;
      align-items: center;
    }
    .callout-image img {
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      max-width: 240px;
      margin: 0 auto;
    }
    .callout-text h2 {
      font-size: clamp(1.7rem, 3vw, 2.3rem);
      font-weight: 700;
    }
    .callout-text > p {
      margin-top: 18px;
      font-size: 1.05rem;
    }
    .callout-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 24px;
    }
    .callout-list span {
      position: relative;
      padding-left: 26px;
      font-size: 0.96rem;
      color: var(--ink);
      font-weight: 500;
    }
    .callout-list span::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--green-bright);
      font-weight: 700;
    }

    /* Showcase (leaderboard) */
    .showcase { padding: 40px 0 90px; }
    .showcase-inner {
      background: var(--green);
      border-radius: 28px;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 40px;
      align-items: center;
      padding: 56px 60px;
    }
    .showcase-text .eyebrow { color: var(--gold); }
    .showcase-text h2 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); }
    .showcase-text p { color: #CFE0CC; margin-top: 16px; font-size: 1.02rem; }
    .showcase-image { display: flex; justify-content: center; }
    .showcase-image img {
      max-width: 220px;
      border-radius: var(--radius);
      box-shadow: 0 20px 40px -12px rgba(0,0,0,0.4);
    }

    /* Pricing */
    .pricing { padding: 30px 0 90px; }
    .pricing-inner { display: flex; justify-content: center; }
    .pricing-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 48px 44px;
      max-width: 460px;
      width: 100%;
      box-shadow: var(--shadow);
      text-align: center;
    }
    .pricing-card h2 { font-size: 1.6rem; margin-top: 6px; }
    .price { margin-top: 20px; }
    .price-amount {
      font-family: 'Outfit', sans-serif;
      font-weight: 800;
      font-size: 2.6rem;
      color: var(--green-bright);
    }
    .price-sub { margin-top: 6px; font-size: 0.88rem; }
    .pricing-list {
      text-align: left;
      margin-top: 30px;
      border-top: 1px solid var(--line);
      padding-top: 26px;
    }
    .pricing-list li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 14px;
      font-size: 0.95rem;
      color: var(--ink);
    }
    .pricing-list li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--green-bright);
      font-weight: 700;
    }

    /* Final CTA */
    .final-cta {
      background: var(--ink);
      padding: 90px 0;
    }
    .final-cta-inner { text-align: center; max-width: 640px; margin: 0 auto; }
    .final-cta h2 { color: #fff; font-size: clamp(1.7rem, 3vw, 2.4rem); }
    .final-cta p { color: #B8C4B5; margin-top: 18px; font-size: 1.05rem; }
    .final-cta .btn { margin-top: 32px; }

    /* Footer */
    .site-footer { padding: 44px 0; }
    .footer-inner { text-align: center; }
    .footer-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .footer-note {
      font-size: 0.82rem;
      max-width: 540px;
      margin: 0 auto 10px;
      color: #8A9587;
    }
    .footer-copy { font-size: 0.8rem; color: #9CA899; }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-visual { order: -1; margin-bottom: 10px; }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
